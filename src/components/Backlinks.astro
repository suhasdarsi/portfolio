---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const allPosts = await getCollection('blog');

const wikiLinkRegex = /\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/g;
const backlinkMap: Record<string, { title: string; slug: string }[]> = {};

allPosts.forEach((post) => {
  const matches = [...post.body.matchAll(wikiLinkRegex)];
  matches.forEach((match) => {
    const linkedSlug = match[1].trim().replace(/ /g, '-').toLowerCase();
    if (!backlinkMap[linkedSlug]) {
      backlinkMap[linkedSlug] = [];
    }
    if (!backlinkMap[linkedSlug].some((b) => b.slug === post.id)) {
      backlinkMap[linkedSlug].push({
        title: post.data.title,
        slug: post.id,
      });
    }
  });
});

const backlinks = backlinkMap[currentSlug] || [];
---

{backlinks.length > 0 && (
  <section class="backlinks">
    <h3 class="backlinks-heading">Linked mentions</h3>
    <div class="backlinks-list">
      {backlinks.map((backlink) => (
        <a href={`/notes/${backlink.slug}`} class="backlink-item">
          {backlink.title}
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .backlinks {
    margin: 4rem 0 0;
    padding: 2rem 0 0;
    border-top: 1px solid var(--color-subtle-border);
  }

  .backlinks-heading {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-muted-foreground);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 0.75rem;
    padding: 0;
  }

  .backlinks-list {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
  }

  .backlink-item {
    display: block;
    margin: 0;
    padding: 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-foreground);
    text-decoration: none;
    line-height: 1.6;
    transition: color 0.3s ease;
  }

  .backlink-item + .backlink-item {
    margin-top: 0.5rem;
  }

  .backlink-item:hover {
    color: var(--color-muted-foreground);
  }
</style>
