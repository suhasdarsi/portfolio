---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const allPosts = (await getCollection('blog')).filter((post) => !post.data.draft);

const wikiLinkRegex = /\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/gs;
const backlinkMap: Record<string, { title: string; slug: string }[]> = {};

allPosts.forEach((post) => {
  if (post.id === currentSlug) return;

  const matches = [...post.body.matchAll(wikiLinkRegex)];
  matches.forEach((match) => {
    const linkedSlug = match[1].trim().replace(/ /g, '-').toLowerCase();
    if (!backlinkMap[linkedSlug]) {
      backlinkMap[linkedSlug] = [];
    }
    if (!backlinkMap[linkedSlug].some((b) => b.slug === post.id)) {
      backlinkMap[linkedSlug].push({
        title: post.data.title,
        slug: post.id,
      });
    }
  });
});

const backlinks = backlinkMap[currentSlug] || [];
---

{backlinks.length > 0 && (
  <section class="backlinks">
    <h3 class="backlinks-heading">Linked mentions</h3>
    <div class="backlinks-list">
      {backlinks.map((backlink) => (
        <a href={`/notes/${backlink.slug}`} class="backlink-item">
          {backlink.title}
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .backlinks {
    margin: 3rem auto 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--color-subtle-border);
    font-family: var(--font-sans);
    color: var(--color-body-text);
  }

  .backlinks-heading {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: 0;
    text-transform: none;
    margin: 0 0 0.75rem;
    padding: 0;
    line-height: 1.4;
  }

  .backlinks-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .backlink-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0.625rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: none;
    line-height: 1.5;
    border-radius: 8px;
    border-bottom: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .backlink-item::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-muted-foreground);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.15s ease;
  }

  .backlink-item:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .backlink-item:hover {
    background: var(--color-muted);
    color: var(--color-foreground);
  }

  .backlink-item:hover::before {
    opacity: 1;
  }
</style>
