---
---

<details class="toc" id="toc">
  <summary class="toc-summary">
    <span>Table of contents</span>
    <svg class="toc-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>
  <nav class="toc-nav" aria-label="Table of contents" id="toc-nav"></nav>
</details>

<script>
  function buildTOC() {
    const content = document.querySelector('.prose-custom');
    const nav = document.getElementById('toc-nav');
    const toc = document.getElementById('toc');
    if (!content || !nav || !toc) return;

    const headings = content.querySelectorAll('h2[id]');
    if (headings.length < 2) {
      toc.remove();
      return;
    }

    const headingData = Array.from(headings).map((h) => ({
      id: h.id,
      text: h.textContent || '',
    }));

    headingData.forEach(({ id, text }) => {
      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = text;
      link.className = 'toc-link';
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(id);
        if (target) {
          const y = target.getBoundingClientRect().top + window.pageYOffset - 120;
          window.scrollTo({ top: y, behavior: 'smooth' });
          history.pushState(null, '', `#${id}`);
        }
      });
      nav.appendChild(link);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            nav.querySelectorAll('.toc-link').forEach((l) => l.classList.remove('toc-link-active'));
            nav.querySelectorAll(`.toc-link[href="#${entry.target.id}"]`).forEach((l) => l.classList.add('toc-link-active'));
          }
        });
      },
      { rootMargin: '-120px 0px -60% 0px', threshold: 1 }
    );

    headings.forEach((h) => observer.observe(h));
  }

  document.addEventListener('DOMContentLoaded', buildTOC);
</script>

<style>
  .toc {
    margin-bottom: 2.5rem;
    padding: 1rem 1.25rem;
    background-color: var(--color-subtle);
    border: 1px solid var(--color-subtle-border);
    border-radius: 8px;
  }

  .toc-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-muted-foreground);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    list-style: none;
    user-select: none;
  }

  .toc-summary::-webkit-details-marker,
  .toc-summary::marker {
    display: none;
    content: '';
  }

  .toc-chevron {
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .toc[open] .toc-chevron {
    transform: rotate(180deg);
  }

  .toc-nav {
    display: flex;
    flex-direction: column;
    padding-top: 0.5rem;
  }

  :global(.toc-link) {
    display: block;
    padding: 0.35rem 0;
    font-family: var(--font-serif);
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.3s ease;
  }

  :global(.toc-link:hover) {
    color: var(--color-foreground);
  }

  :global(.toc-link-active) {
    color: var(--color-foreground);
    font-weight: 500;
  }
</style>
