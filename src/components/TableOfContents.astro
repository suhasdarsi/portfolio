---
---

<nav class="toc" aria-label="Table of contents" id="toc">
  <details>
    <summary class="toc-heading">Table of contents</summary>
    <div class="toc-links" id="toc-nav"></div>
  </details>
</nav>

<script>
  function buildTOC() {
    const content = document.querySelector('.prose-custom');
    const nav = document.getElementById('toc-nav');
    const toc = document.getElementById('toc');
    if (!content || !nav || !toc) return;

    const headings = content.querySelectorAll('h2[id]');
    if (headings.length < 2) {
      toc.remove();
      return;
    }

    headings.forEach((h) => {
      const link = document.createElement('a');
      link.href = `#${encodeURIComponent(h.id)}`;
      link.textContent = h.textContent || '';
      link.className = 'toc-link';
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(h.id);
        if (target) {
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const y = target.getBoundingClientRect().top + window.pageYOffset - 120;
          window.scrollTo({ top: y, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
          history.pushState(null, '', `#${encodeURIComponent(h.id)}`);
        }
      });
      nav.appendChild(link);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            nav.querySelectorAll('.toc-link').forEach((l) => l.classList.remove('toc-link-active'));
            nav.querySelectorAll('.toc-link').forEach((link) => {
              if (link.getAttribute('href') === `#${encodeURIComponent(entry.target.id)}`) {
                link.classList.add('toc-link-active');
              }
            });
          }
        });
      },
      { rootMargin: '-120px 0px -60% 0px', threshold: 1 }
    );

    headings.forEach((h) => observer.observe(h));

    window.addEventListener('beforeunload', () => {
      observer.disconnect();
    });
  }

  document.addEventListener('DOMContentLoaded', buildTOC);
</script>

<style>
  .toc {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-subtle-border);
  }

  .toc-heading {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    cursor: pointer;
    user-select: none;
    list-style: none;
  }

  .toc-heading::-webkit-details-marker {
    display: none;
  }

  .toc-heading::before {
    content: '+';
    display: inline-block;
    margin-right: 0.375rem;
    font-weight: 400;
  }

  .toc[open] .toc-heading::before {
    content: '−';
  }

  .toc-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.75rem;
  }

  .toc-link {
    display: block;
    padding: 0.25rem 0;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.2s ease;
  }

  .toc-link:hover {
    color: var(--color-foreground);
  }

  .toc-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .toc-link-active {
    color: var(--color-foreground);
    font-weight: 500;
  }
</style>
