---
import { render, type CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/date';

interface Props {
  card: CollectionEntry<'cards'>;
  connections: CollectionEntry<'cards'>[];
}

const { card, connections } = Astro.props;
const { Content } = await render(card);
---

<article class="idea-card">
  <header class="idea-card-header">
    <div>
      <h2 class="idea-card-title">
        <a href={`/cards/${card.id}`}>{card.data.title}</a>
      </h2>
      <p class="idea-card-description">{card.data.description}</p>
    </div>
    <a href={`/cards/${card.id}`} class="idea-card-open" aria-label={`Open ${card.data.title}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"></path>
        <path d="m13 6 6 6-6 6"></path>
      </svg>
    </a>
  </header>

  <div class="idea-card-body">
    <Content />
  </div>

  {connections.length > 0 && (
    <div class="idea-card-links" aria-label={`Notes linked to ${card.data.title}`}>
      {connections.map((connection) => (
        <a href={`/cards/${connection.id}`}>{connection.data.title}</a>
      ))}
    </div>
  )}

  <footer class="idea-card-footer">
    <time datetime={card.data.pubDate.toISOString()}>{formatDate(card.data.pubDate)}</time>
    <div class="idea-card-footer-meta">
      <span class="idea-card-topic">{card.data.topic}</span>
    </div>
  </footer>
</article>

<style>
  .idea-card {
    display: flex;
    flex-direction: column;
    padding: clamp(1.25rem, 4vw, 1.75rem);
    border-radius: 18px;
    background: var(--color-subtle);
    box-shadow: inset 0 0 0 1px var(--color-border), var(--shadow-subtle);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .idea-card:hover {
    transform: translateY(-2px);
    box-shadow: inset 0 0 0 1px var(--color-border), var(--shadow-elevated);
  }

  .idea-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .idea-card-header > div {
    min-width: 0;
  }

  .idea-card-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.2rem;
    font-weight: 650;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .idea-card-title a {
    color: var(--color-foreground);
    text-decoration: none;
  }

  .idea-card-title a:focus-visible,
  .idea-card-open:focus-visible,
  .idea-card-links a:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .idea-card-description {
    margin: 0.35rem 0 0;
    color: var(--color-body-text);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .idea-card-open {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: var(--color-muted);
    color: var(--color-muted-foreground);
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  .idea-card-open:hover {
    color: var(--color-foreground);
    background: var(--color-background);
    transform: translateX(2px);
  }

  .idea-card-body {
    margin-top: 1.15rem;
    color: var(--color-body-text);
    font-family: var(--font-sans);
    font-size: 0.925rem;
    line-height: 1.7;
  }

  .idea-card-body :global(p) {
    margin: 0 0 0.85rem;
  }

  .idea-card-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .idea-card-links {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.925rem;
    line-height: 1.7;
  }

  .idea-card-links a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .idea-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
    color: var(--color-muted-foreground);
    font-family: var(--font-sans);
    font-size: 0.7rem;
  }

  .idea-card-footer-meta {
    display: inline-flex;
    align-items: center;
  }

  .idea-card-footer-meta {
    gap: 0.5rem;
  }

  .idea-card-topic {
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    background: var(--color-muted);
    color: var(--color-body-text);
  }

  @media (max-width: 480px) {
    .idea-card {
      padding: 1.25rem;
    }

    .idea-card-footer-meta {
      gap: 0.35rem;
    }
  }
</style>
