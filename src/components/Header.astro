---
export interface Props {
  showNav?: boolean;
  showSearch?: boolean;
}

const { showNav = true, showSearch = true } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner">
    {showNav ? (
      <nav class="nav-links">
        <a href="/" class="nav-link" aria-current={currentPath === '/' ? 'page' : undefined}>Home</a>
        <a href="/cards" class="nav-link" aria-current={currentPath.startsWith('/cards') ? 'page' : undefined}>Notes</a>
        <a href="/uses" class="nav-link" aria-current={currentPath === '/uses' ? 'page' : undefined}>Uses</a>
      </nav>
    ) : (
      <a href="/" class="nav-link">Home</a>
    )}
    <div class="header-actions">
      {showSearch && (
        <button type="button" class="search-trigger" id="global-search-toggle" aria-label="Open search" aria-expanded="false" aria-controls="global-search-overlay">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-trigger-icon"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.34-4.34"></path></svg>
          <span class="search-trigger-label">Search</span>
          <kbd class="search-trigger-kbd">⌘K</kbd>
        </button>
      )}
      <button type="button" class="theme-toggle" id="theme-toggle" aria-label="Switch to dark theme">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-sun"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-moon"><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"></path></svg>
      </button>
    </div>
  </div>
</header>

{showSearch && (
  <>
    <div class="search-overlay" id="global-search-overlay" role="dialog" aria-modal="true" aria-label="Search site" aria-hidden="true" inert hidden>
      <div class="search-dialog">
        <div class="search-input-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-dialog-icon"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.34-4.34"></path></svg>
          <input type="text" id="global-search-input" class="search-input-dialog" placeholder="Search notes..." aria-label="Search site" autocomplete="off" />
          <kbd class="search-esc">Esc</kbd>
        </div>
        <div class="search-results" id="global-search-results"></div>
        <p class="search-empty hidden" id="global-search-empty">No notes found.</p>
        <div class="search-footer">
          <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
          <span><kbd>↵</kbd> open</span>
          <span><kbd>Esc</kbd> close</span>
        </div>
      </div>
    </div>
  </>
)}

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  const searchToggle = document.getElementById('global-search-toggle');
  const searchOverlay = document.getElementById('global-search-overlay');
  const searchInput = document.getElementById('global-search-input') as HTMLInputElement;
  const searchResults = document.getElementById('global-search-results');
  const searchEmpty = document.getElementById('global-search-empty');
  let activeResultIndex = -1;

  type SearchPost = {
    href: string;
    title: string;
    description?: string;
    body?: string;
  };

  let searchPosts: SearchPost[] = [];
  let searchReady: Promise<void> | undefined;
  let fuse: { search: (query: string) => Array<{ item: SearchPost }> } | undefined;

  async function loadSearch() {
    if (!searchReady) {
      searchReady = Promise.all([
        fetch('/search.json').then((response) => {
          if (!response.ok) throw new Error('Unable to load search data');
          return response.json() as Promise<SearchPost[]>;
        }),
        import('fuse.js'),
      ]).then(([posts, { default: Fuse }]) => {
        searchPosts = posts;
        fuse = new Fuse(searchPosts, {
          keys: [
            { name: 'title', weight: 0.5 },
            { name: 'description', weight: 0.3 },
            { name: 'body', weight: 0.2 },
          ],
          threshold: 0.3,
          ignoreLocation: true,
        });
      }).catch((error) => {
        searchReady = undefined;
        console.error(error);
      });
    }

    return searchReady;
  }

  function getTheme() {
    const stored = localStorage.getItem('theme');
    if (stored) return stored;
    return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function setTheme(theme: string) {
    localStorage.setItem('theme', theme);
    if (theme === 'dark') {
      html.classList.add('dark');
    } else {
      html.classList.remove('dark');
    }
    themeToggle?.setAttribute('aria-label', theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
  }

  setTheme(getTheme());

  themeToggle?.addEventListener('click', () => {
    const current = html.classList.contains('dark') ? 'dark' : 'light';
    setTheme(current === 'dark' ? 'light' : 'dark');
  });

  function getResultItems() {
    return Array.from(searchResults?.querySelectorAll<HTMLAnchorElement>('.search-result-item') || []);
  }

  function setActiveResult(index: number) {
    const items = getResultItems();
    if (items.length === 0) {
      activeResultIndex = -1;
      return;
    }

    const safeIndex = Math.max(0, Math.min(index, items.length - 1));
    activeResultIndex = safeIndex;
    items.forEach((item, itemIndex) => item.classList.toggle('active', itemIndex === safeIndex));
    items[safeIndex]?.scrollIntoView({ block: 'nearest' });
  }

  function renderResults(items: SearchPost[]) {
    if (!searchResults) return;
    searchResults.replaceChildren();

    items.forEach((post) => {
      const link = document.createElement('a');
      link.href = post.href;
      link.className = 'search-result-item';

      const title = document.createElement('span');
      title.className = 'search-result-title';
      title.textContent = post.title;

      link.append(title);
      searchResults.appendChild(link);
    });

    setActiveResult(items.length > 0 ? 0 : -1);
  }

  function getFocusableElements(): HTMLElement[] {
    if (!searchOverlay) return [];
    return Array.from(
      searchOverlay.querySelectorAll<HTMLElement>('input, [tabindex]:not([tabindex="-1"]), a[href]')
    );
  }

  async function openSearch() {
    searchOverlay?.removeAttribute('hidden');
    searchOverlay?.classList.add('open');
    searchOverlay?.removeAttribute('inert');
    searchOverlay?.setAttribute('aria-hidden', 'false');
    searchToggle?.setAttribute('aria-expanded', 'true');
    searchInput?.focus();
    await loadSearch();
    if (!searchOverlay?.classList.contains('open')) return;
    renderResults(searchPosts);
    searchEmpty?.classList.add('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    searchOverlay?.classList.remove('open');
    searchOverlay?.setAttribute('inert', '');
    searchOverlay?.setAttribute('aria-hidden', 'true');
    searchOverlay?.setAttribute('hidden', '');
    searchToggle?.setAttribute('aria-expanded', 'false');
    if (searchInput) searchInput.value = '';
    searchResults?.replaceChildren();
    searchEmpty?.classList.add('hidden');
    activeResultIndex = -1;
    document.body.style.overflow = '';
    searchToggle?.focus();
  }

  const handleSearchToggle = () => openSearch();
  const handleOverlayClick = (e: Event) => {
    if (e.target === searchOverlay) closeSearch();
  };

  searchToggle?.addEventListener('click', handleSearchToggle);
  searchOverlay?.addEventListener('click', handleOverlayClick);

  searchInput?.addEventListener('input', async () => {
    await loadSearch();
    const query = searchInput.value.trim();
    if (!query) {
      renderResults(searchPosts);
      searchEmpty?.classList.add('hidden');
      return;
    }

    const results = fuse?.search(query).map((result) => result.item) ?? [];
    if (results.length === 0) {
      searchResults?.replaceChildren();
      searchEmpty?.classList.remove('hidden');
      setActiveResult(-1);
      return;
    }

    renderResults(results);
    searchEmpty?.classList.add('hidden');
  });

  const handleKeydown = (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      searchOverlay?.classList.contains('open') ? closeSearch() : openSearch();
      return;
    }

    if (!searchOverlay?.classList.contains('open')) return;

    if (e.key === 'Tab') {
      e.preventDefault();
      const focusable = getFocusableElements();
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        (document.activeElement === first ? last : first).focus();
      } else {
        (document.activeElement === last ? first : last).focus();
      }
      return;
    }

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      const items = getResultItems();
      if (items.length === 0) return;
      setActiveResult(activeResultIndex < 0 ? 0 : activeResultIndex + 1);
      return;
    }

    if (e.key === 'ArrowUp') {
      e.preventDefault();
      const items = getResultItems();
      if (items.length === 0) return;
      setActiveResult(activeResultIndex < 0 ? items.length - 1 : activeResultIndex - 1);
      return;
    }

    if (e.key === 'Enter') {
      const items = getResultItems();
      if (items.length === 0) return;
      const targetIndex = activeResultIndex >= 0 ? activeResultIndex : 0;
      items[targetIndex]?.click();
      return;
    }

    if (e.key === 'Escape') closeSearch();
  };

  document.addEventListener('keydown', handleKeydown);

  window.addEventListener('beforeunload', () => {
    document.removeEventListener('keydown', handleKeydown);
    searchToggle?.removeEventListener('click', handleSearchToggle);
    searchOverlay?.removeEventListener('click', handleOverlayClick);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 0;
    background-color: color-mix(in srgb, var(--color-background) 88%, transparent);
    backdrop-filter: blur(18px) saturate(1.2);
    -webkit-backdrop-filter: blur(18px) saturate(1.2);
  }

  .header-inner {
    max-width: var(--max-width-shell);
    margin: 0 auto;
    padding: 0 1rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 440;
    color: var(--color-muted-foreground);
  }

  .nav-link {
    color: var(--color-muted-foreground);
    text-decoration: none;
    padding: 0.4rem 0;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-link:hover,
  .nav-link[aria-current="page"] {
    color: var(--color-foreground);
  }

  .nav-link[aria-current="page"] {
    font-weight: 560;
  }

  .nav-link[aria-current="page"]::after {
    content: none;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .nav-sep {
    display: none;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .theme-toggle {
    width: 2.25rem;
    height: 2.25rem;
    padding-inline: 0;
    padding-block: 0;
    color: var(--color-muted-foreground);
    background: transparent;
    border: 0;
    border-radius: var(--radius-buttons);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .theme-toggle:hover {
    color: var(--color-foreground);
    border-color: var(--color-muted-foreground);
    background: var(--color-muted);
  }

  :global(html:not(.dark)) .theme-toggle .icon-sun {
    display: none;
  }

  :global(html:not(.dark)) .theme-toggle .icon-moon {
    display: block;
  }

  :global(html.dark) .theme-toggle .icon-sun {
    display: block;
  }

  :global(html.dark) .theme-toggle .icon-moon {
    display: none;
  }

  .theme-toggle svg {
    width: 1rem;
    height: 1rem;
  }

  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 0;
    border-radius: var(--radius-buttons);
    background: transparent;
    color: var(--color-muted-foreground);
    cursor: pointer;
    padding: 0.48rem 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    box-shadow: none;
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .search-trigger:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .search-trigger:hover {
    color: var(--color-foreground);
    background: var(--color-muted);
  }

  .search-trigger-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  .search-trigger-label {
    display: inline;
  }

  .search-trigger-kbd {
    display: none !important;
    border: 1px solid var(--color-subtle-border);
    background-color: var(--color-muted);
    border-radius: var(--radius-buttons);
    padding: 0.05rem 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-muted-foreground);
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: var(--color-overlay);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 18vh;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .search-overlay[hidden] {
    display: none;
  }

  .search-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .search-dialog {
    width: 100%;
    max-width: 38rem;
    margin: 0 1rem;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.3);
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    padding: 1rem;
    border-bottom: 0;
    gap: 0.75rem;
  }

  .search-dialog-icon {
    width: 1rem;
    height: 1rem;
    color: var(--color-muted-foreground);
    flex-shrink: 0;
  }

  .search-input-dialog {
    flex: 1;
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-foreground);
    outline: none;
  }

  .search-input-dialog::placeholder {
    color: var(--color-muted-foreground);
  }

  .search-esc {
    display: none;
  }

  .search-results {
    max-height: 60vh;
    padding: 0.375rem;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .search-results::-webkit-scrollbar {
    display: none;
  }

  :global(.search-result-item) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    border-bottom: 0;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  :global(.search-result-item:hover),
  :global(.search-result-item.active),
  :global(.search-result-item:focus-visible) {
    background-color: var(--color-muted);
  }

  :global(.search-result-item:focus-visible) {
    outline: 1px solid var(--color-foreground);
    outline-offset: -1px;
  }

  :global(.search-result-title) {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-foreground);
    margin: 0;
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.search-result-type) {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    flex-shrink: 0;
  }

  .search-empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-muted-foreground);
    padding: 2rem 1rem;
    text-align: center;
  }

  .search-footer {
    display: none;
    align-items: center;
    gap: 1.25rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--color-subtle-border);
    color: var(--color-muted-foreground);
    font-size: var(--text-small);
  }

  .search-footer kbd {
    border: 1px solid var(--color-subtle-border);
    background: var(--color-muted);
    color: inherit;
    border-radius: 4px;
    padding: 0.1rem 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    margin-right: 0.25rem;
  }

  @media (max-width: 40rem) {
    .header-inner {
      padding-inline: 0.875rem;
    }

    .nav-links {
      gap: 1rem;
      font-size: 0.8125rem;
    }

    .header-actions {
      gap: 0.125rem;
    }

    .search-trigger {
      width: 2.25rem;
      height: 2.25rem;
      padding-inline: 0;
      padding-block: 0;
      justify-content: center;
    }

    .search-trigger-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding-inline: 0;
      padding-block: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
</style>
