---
---

<div class="search-container">
  <input
    type="text"
    id="search-input"
    class="search-input"
    placeholder="Search..."
    autocomplete="off"
  />
</div>

<script>
  import Fuse from 'fuse.js';

  const searchData = document.getElementById('search-data');
  const posts = searchData ? JSON.parse(searchData.textContent || '[]') : [];

  const fuse = new Fuse(posts, {
    keys: [
      { name: 'title', weight: 0.5 },
      { name: 'description', weight: 0.5 },
    ],
    threshold: 0.3,
    ignoreLocation: true,
  });

  const input = document.getElementById('search-input') as HTMLInputElement;
  const articles = document.querySelectorAll('[data-searchable]');
  const emptyMsg = document.getElementById('search-empty');

  input.addEventListener('input', () => {
    const query = input.value.trim();

    if (!query) {
      articles.forEach((el) => el.classList.remove('hidden'));
      if (emptyMsg) emptyMsg.classList.add('hidden');
      return;
    }

    const results = new Set(fuse.search(query).map((r) => r.item.id));
    let visibleCount = 0;

    articles.forEach((el) => {
      const id = el.getAttribute('data-post-id');
      if (id && results.has(id)) {
        el.classList.remove('hidden');
        visibleCount++;
      } else {
        el.classList.add('hidden');
      }
    });

    if (emptyMsg) {
      if (visibleCount === 0) emptyMsg.classList.remove('hidden');
      else emptyMsg.classList.add('hidden');
    }
  });
</script>

<style>
  .search-container {
    margin-bottom: 2rem;
  }

  .search-input {
    width: 100%;
    padding: 0.25rem 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-foreground);
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-subtle-border);
    outline: none;
    text-decoration: none;
    box-shadow: none;
    -webkit-appearance: none;
    transition: border-color var(--duration-400);
  }

  .search-input::placeholder {
    color: var(--color-muted-foreground);
    font-style: italic;
  }

  .search-input:focus {
    border-bottom-color: var(--color-foreground);
  }

  .search-empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-muted-foreground);
    padding: 2rem 0;
  }

  .hidden {
    display: none !important;
  }
</style>
