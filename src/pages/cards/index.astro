---
import { getConnectedCards, getPublishedCardEntriesByOrder } from '../../utils/content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import CardPreview from '../../components/CardPreview.astro';

const cards = await getPublishedCardEntriesByOrder();

const connectionsFor = (cardId: string) => {
  const card = cards.find((entry) => entry.id === cardId);
  return card ? getConnectedCards(card, cards) : [];
};
---

<BlogLayout title="Notes | Suhas Darsi" description="Short, connected notes about AI security, agent systems, resilience, and network risk.">
  <header class="cards-header">
    <h1>Notes</h1>
    <p class="cards-intro">A public collection of short, connected ideas about AI security and resilient systems.</p>
    <div class="cards-meta">
      <span>{cards.length} notes</span>
      <span aria-hidden="true">·</span>
      <span>Newest first</span>
    </div>
  </header>

  <section class="cards-grid" aria-label="Short notes">
    {cards.map((card) => <CardPreview card={card} connections={connectionsFor(card.id)} />)}
  </section>
</BlogLayout>

<style>
  .cards-header {
    max-width: var(--max-width-shell);
    margin: 0 auto 1.75rem;
  }

  .cards-header h1 {
    margin: 0 0 0.35rem;
    font-family: var(--font-sans);
    font-size: 2.25rem;
    font-weight: 680;
    line-height: 1.1;
    letter-spacing: -0.035em;
  }

  .cards-intro {
    max-width: 34rem;
    margin: 0;
    color: var(--color-body-text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .cards-meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.9rem;
    color: var(--color-muted-foreground);
    font-family: var(--font-sans);
    font-size: 0.72rem;
  }

  .cards-grid {
    display: grid;
    max-width: var(--max-width-shell);
    margin-inline: auto;
    grid-template-columns: 1fr;
    gap: 0.9rem;
  }
</style>
