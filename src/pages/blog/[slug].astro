---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import Backlinks from '../../components/Backlinks.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { formatDateWithYear } from '../../utils/date';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
---

<BlogLayout title={`${post.data.title} | Suhas Darsi`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "author": { "@type": "Person", "name": "Suhas Darsi" },
    "url": `https://suhasdarsi.com/blog/${post.id}`
  })} />
  <article>
    <a href="/blog" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5"></path>
        <path d="m12 19-7-7 7-7"></path>
      </svg>
      Back to Blog
    </a>
    
    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="article-meta">
        <div class="article-date">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
            <line x1="16" x2="16" y1="2" y2="6"></line>
            <line x1="8" x2="8" y1="2" y2="6"></line>
            <line x1="3" x2="21" y1="10" y2="10"></line>
          </svg>
          <time datetime={post.data.pubDate.toISOString()}>{formatDateWithYear(post.data.pubDate)}</time>
        </div>
        {post.data.tags.length > 0 && (
          <div class="tag-list">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </div>
    </header>

    <TableOfContents />

    <div class="prose-custom">
      <Content />
    </div>

    <Backlinks currentSlug={post.id} />
  </article>
</BlogLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    font-size: var(--text-body);
    margin-bottom: 2.5rem;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .back-link:hover {
    color: var(--color-foreground);
    gap: 0.5rem;
  }

  .back-link svg {
    transition: transform 0.3s ease;
  }

  .back-link:hover svg {
    transform: translateX(-3px);
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-title {
    font-size: var(--text-display-sm);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .article-title {
      font-size: var(--text-display);
    }
  }

  .article-description {
    font-size: var(--text-body-lg);
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .article-date {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
  }

  .article-date svg {
    opacity: 0.5;
  }
</style>
