---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const searchData = posts.map((post) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
}));
---

<BlogLayout title="Blog | Suhas Darsi" description="My digital garden - thoughts on building products, self-hosting, and more">
  <div>
    <script id="search-data" type="application/json" set:html={JSON.stringify(searchData)} />

    <div class="post-list" id="post-list">
      {posts.map((post) => (
        <article class="post-item" data-searchable data-post-id={post.id}>
          <a href={`/blog/${post.id}`} class="post-link">
            <h2 class="post-title">
              {post.data.title}
            </h2>
            <p class="post-desc">
              {post.data.description}
            </p>
            <div class="post-meta">
              <div class="post-date">
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</BlogLayout>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-subtle-border);
  }

  .post-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .post-link:hover {
    color: var(--color-muted-foreground);
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  .post-desc {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin: 0 0 0.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>
