---
import BlogLayout from '../../layouts/BlogLayout.astro';
import Search from '../../components/Search.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const searchData = posts.map((post) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
}));

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<BlogLayout title="Blog | Suhas Darsi" description="My digital garden - thoughts on building products, self-hosting, and more">
  <div>
    <Search />

    <script id="search-data" type="application/json" set:html={JSON.stringify(searchData)} />

    <div class="space-y-10" id="post-list">
      {posts.map((post) => (
        <article class="group" data-searchable data-post-id={post.id}>
          <a href={`/blog/${post.id}`} class="block">
            <div class="flex flex-col gap-3">
              <h2 class="font-serif text-xl font-medium group-hover:text-muted-foreground transition-colors" style="font-family: var(--font-serif);">
                {post.data.title}
              </h2>
              <p class="text-body text-muted-foreground leading-relaxed">
                {post.data.description}
              </p>
              <div class="flex items-center gap-4 flex-wrap">
                <div class="text-small text-muted-foreground uppercase tracking-wide">
                  <time datetime={post.data.pubDate}>{formatDate(post.data.pubDate)}</time>
                </div>
                {post.data.tags.length > 0 && (
                  <div class="tag-list">
                    {post.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
    <p id="search-empty" class="search-empty hidden">No posts found.</p>
  </div>
</BlogLayout>
