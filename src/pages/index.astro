---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { formatDate, getReadingTime } from '../utils/date';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MaturityBadge from '../components/MaturityBadge.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const recentPosts = posts.slice(0, 5);

const recentTopics = posts.slice(0, 3).flatMap((p) => p.data.topics);
const currentlyThinking = [...new Set(recentTopics)].slice(0, 3);

const updatedPosts = posts
  .filter((p) => p.data.updatedDate)
  .sort((a, b) => new Date(b.data.updatedDate!).valueOf() - new Date(a.data.updatedDate!).valueOf())
  .slice(0, 3);

const totalNotes = posts.length;
const totalTopics = [...new Set(posts.flatMap((p) => p.data.topics))].length;
const evergreenCount = posts.filter((p) => p.data.maturity === 'evergreen').length;

const siteUrl = 'https://suhasdarsi.com';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Astro" />
    <meta name="description" content="Suhas Darsi - Co-Founder at SuperAlign, writing about AI safety, product, bags, travel, and infrastructure." />
    <meta name="author" content="Suhas Darsi" />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:title" content="Suhas Darsi" />
    <meta property="og:description" content="Co-Founder at SuperAlign, building foundational infrastructure for AI safety." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Suhas Darsi" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@suhas_darsi" />
    <meta name="twitter:creator" content="@suhas_darsi" />
    <meta name="theme-color" content="#faf8f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <title>Suhas Darsi</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background">
    <Header />

    <main class="max-w-3xl mx-auto px-6 pt-12 pb-8">
      <h1 class="home-name">
        Suhas Darsi
      </h1>
      <p class="home-tagline">
        Building AI safety infrastructure. Writing about the systems we build and the systems that build us.
      </p>

      <div class="currently-thinking">
        <span class="ct-label">Currently thinking about</span>
        <div class="ct-topics">
          {currentlyThinking.map((topic) => (
            <a href={`/notes?topic=${topic}`} class="ct-topic">{topic}</a>
          ))}
        </div>
      </div>

      <div class="home-socials">
        <a href="https://www.linkedin.com/in/suhasdarsi/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="X (Twitter)">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://booking.akiflow.com/suhas--e823" target="_blank" rel="noopener noreferrer" class="social-link-text">
          Book a meeting
        </a>
      </div>

      {updatedPosts.length > 0 && (
        <div class="updated-section">
          <h2 class="section-heading">Recently updated</h2>
          <div class="updated-list">
            {updatedPosts.map((post) => (
              <a href={`/notes/${post.id}`} class="updated-item">
                <span class="updated-title">{post.data.title}</span>
                <time datetime={post.data.updatedDate!.toISOString()} class="updated-date">{formatDate(post.data.updatedDate!)}</time>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="recent-section">
        <div class="recent-header">
          <h2 class="section-heading">Recent notes</h2>
          <div class="garden-stats">
            <span class="stat">{totalNotes} notes</span>
            <span class="stat-sep">·</span>
            <span class="stat">{totalTopics} topics</span>
            <span class="stat-sep">·</span>
            <span class="stat">{evergreenCount} evergreen</span>
          </div>
        </div>
        <div class="recent-posts">
          {recentPosts.map((post, i) => {
            const readingTime = getReadingTime(post.body ?? '');
            return (
              <article class="recent-item" style={`animation-delay: ${i * 80}ms`}>
                <a href={`/notes/${post.id}`} class="recent-link">
                  <div class="flex flex-col gap-2">
                    <div class="recent-meta-top">
                      <MaturityBadge maturity={post.data.maturity} />
                      <span class="recent-reading-time">{readingTime} min</span>
                    </div>
                    <h3 class="recent-title">
                      {post.data.title}
                    </h3>
                    <p class="recent-desc">
                      {post.data.description}
                    </p>
                    <div class="recent-date">
                      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
        <div class="home-links">
          <a href="/notes" class="home-link">
            View all notes
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
          <a href="/about" class="home-link">
            About me
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .home-name {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    opacity: 0;
    animation: fadeUp 0.6s ease-out forwards;
  }

  @media (min-width: 768px) {
    .home-name {
      font-size: var(--text-display);
    }
  }

  .home-tagline {
    font-size: var(--text-body-lg);
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s ease-out 0.15s forwards;
  }

  .currently-thinking {
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease-out 0.25s forwards;
  }

  .ct-label {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .ct-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ct-topic {
    font-size: var(--text-body);
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.3s ease;
  }

  .ct-topic:hover {
    text-decoration-color: var(--color-muted-foreground);
  }

  .home-socials {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.6s ease-out 0.35s forwards;
  }

  .social-icon {
    color: var(--color-muted-foreground);
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .social-icon:hover {
    color: var(--color-foreground);
    transform: scale(1.1);
  }

  .social-link-text {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 0.3s ease, text-decoration-color 0.3s ease;
  }

  .social-link-text:hover {
    color: var(--color-foreground);
    text-decoration-color: var(--color-muted-foreground);
  }

  .updated-section {
    margin-bottom: 3rem;
    border-top: 1px solid var(--color-subtle-border);
    padding-top: 2.5rem;
  }

  .updated-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .updated-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .updated-item:hover {
    color: var(--color-muted-foreground);
  }

  .updated-title {
    font-family: var(--font-serif);
    font-size: var(--text-body);
  }

  .updated-date {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .recent-section {
    border-top: 1px solid var(--color-subtle-border);
    padding-top: 2.5rem;
  }

  .recent-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: var(--text-title);
    margin: 0;
  }

  .garden-stats {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
  }

  .stat-sep {
    margin: 0 0.25rem;
  }

  .recent-posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .recent-item {
    opacity: 0;
    animation: fadeUp 0.5s ease-out forwards;
  }

  .recent-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-subtle-border);
    transition: border-color 0.3s ease;
  }

  .recent-item:last-child .recent-link {
    border-bottom: none;
    padding-bottom: 0;
  }

  .recent-link:hover {
    border-bottom-color: var(--color-foreground);
  }

  .recent-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .recent-reading-time {
    font-size: var(--text-caption);
    color: var(--color-muted-foreground);
  }

  .recent-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .recent-link:hover .recent-title {
    color: var(--color-muted-foreground);
  }

  .recent-desc {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.6;
  }

  .recent-date {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 0.125rem;
  }

  .home-links {
    display: flex;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .home-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 0.3s ease, text-decoration-color 0.3s ease, gap 0.3s ease;
  }

  .home-link:hover {
    color: var(--color-foreground);
    text-decoration-color: var(--color-muted-foreground);
    gap: 0.75rem;
  }

  .home-link svg {
    transition: transform 0.3s ease;
  }

  .home-link:hover svg {
    transform: translateX(3px);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
