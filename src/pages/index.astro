          Book a meeting
        </a>
      </div>

      <div class="border-t border-subtle-border pt-10">
        <h2 class="font-serif text-title mb-8" style="font-family: var(--font-serif);">Recent writing</h2>
        <div class="space-y-8">
          {posts.map((post) => (
            <article class="group">
              <a href={`/blog/${post.id}`} class="block">
                <div class="flex flex-col gap-2">
                  <h3 class="font-serif text-lg font-medium group-hover:text-muted-foreground transition-colors" style="font-family: var(--font-serif);">
                    {post.data.title}
                  </h3>
                  <p class="text-body text-muted-foreground leading-relaxed">
                    {post.data.description}
                  </p>
                  <div class="text-small text-muted-foreground uppercase tracking-wide">
                    <time datetime={post.data.pubDate}>{formatDate(post.data.pubDate)}</time>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
        <a href="/blog" class="inline-block mt-8 text-body text-muted-foreground hover:text-foreground transition-colors underline decoration-2 decoration-[#a19c87] underline-offset-4">
          View all posts →
        </a>
