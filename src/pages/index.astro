---
import { getPublishedCardEntriesByOrder } from '../utils/content';
import { formatDate } from '../utils/date';
import BlogLayout from '../layouts/BlogLayout.astro';

const cards = await getPublishedCardEntriesByOrder();
const recentCards = cards.slice(0, 3);

const currently = [
  { label: 'Founder', name: 'SuperAlign AI', url: 'https://superalign.ai' },
  { label: 'Chair at AI Alignment Chapter', name: 'RIMAS Singapore', url: 'https://www.rimas.org.sg/' },
  { label: 'Guest Lecturer', name: 'SUSS', url: 'https://www.suss.edu.sg/' },
];

const previously = [
  { label: 'Founder', name: 'Aztlan', url: 'https://www.linkedin.com/company/aztlan/' },
  { label: 'Masters in AI', name: 'IIIT Hyderabad', url: 'https://www.iiit.ac.in/' },
  { label: 'Bachelors', name: 'IIIT Hyderabad', url: 'https://www.iiit.ac.in/' },
];
---

<BlogLayout title="Suhas Darsi" description="Suhas Darsi — short, connected ideas about AI security, agent systems, and network risk.">
  <p class="home-kicker">Founder · Researcher · Writer</p>
  <h1 class="home-name">
    Suhas Darsi
  </h1>
  <p class="home-bio home-lede">
    I'm a co-founder at <a href="https://superalign.ai" class="bio-link link-underline">SuperAlign</a>, where we help security teams see, understand, and control AI adoption across their organizations.
  </p>
  <p class="home-bio">
    My background is in Computer Vision research at IIIT Hyderabad. These days I focus on how AI systems fail, how risk propagates through connected agents, and the controls required to deploy them safely.
  </p>
  <p class="home-bio">
    This site is where I publish short, connected notes on AI security, agent architecture, and the network dynamics behind systemic failures.
  </p>

  <div class="cta-row">
    <a href="https://booking.akiflow.com/suhas--e823" target="_blank" rel="noopener noreferrer" class="cta-button">
      Say Hello
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </a>

    <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="rss-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 11a9 9 0 0 1 9 9"></path>
        <path d="M4 4a16 16 0 0 1 16 16"></path>
        <circle cx="5" cy="19" r="1"></circle>
      </svg>
      Subscribe via RSS
    </a>

    <div class="home-socials">
      <a href="https://www.linkedin.com/in/suhasdarsi/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="X (Twitter)">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="timeline-section">
    <div class="timeline-group">
      <h2 class="timeline-label">Currently</h2>
      <ul class="timeline-list">
        {currently.map((item) => (
          <li class="timeline-item">
            <span class="timeline-role">{item.label}</span> at <a href={item.url} class="section-link link-underline" target="_blank" rel="noopener noreferrer">{item.name}</a>
          </li>
        ))}
      </ul>
    </div>
    <div class="timeline-group">
      <h2 class="timeline-label">Previously</h2>
      <ul class="timeline-list">
        {previously.map((item) => (
          <li class="timeline-item">
            <span class="timeline-role">{item.label}</span> at <a href={item.url} class="section-link link-underline" target="_blank" rel="noopener noreferrer">{item.name}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="recent-section">
    <h2 class="section-heading">Latest notes</h2>
    <div class="recent-posts">
      {recentCards.map((card) => (
          <article class="recent-item">
            <a href={`/cards/${card.id}`} class="recent-link">
              <div class="flex flex-col gap-2">
                <h3 class="recent-title">
                  {card.data.title}
                </h3>
                <p class="recent-desc">
                  {card.data.description}
                </p>
                <div class="recent-date">
                  <span>{card.data.topic}</span>
                  <span aria-hidden="true">·</span>
                  <time datetime={card.data.pubDate.toISOString()}>{formatDate(card.data.pubDate)}</time>
                </div>
              </div>
            </a>
          </article>
      ))}
    </div>
    <a href="/cards" class="view-all-link">
      Explore all notes
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </a>
  </div>
</BlogLayout>

<style>
  .home-name {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 10vw, var(--text-display));
    line-height: 1.08;
    margin: 0 0 1.75rem;
    letter-spacing: -0.02em;
    text-wrap: balance;
    font-weight: 540;
  }

  .home-kicker {
    margin: 0 0 0.75rem;
    color: var(--color-muted-foreground);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 520;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .home-bio {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-body-text);
    line-height: 1.72;
    margin-bottom: 1.25rem;
    max-width: 44rem;
    text-wrap: pretty;
  }

  .home-lede {
    color: var(--color-foreground);
    font-size: clamp(1.125rem, 2.25vw, 1.25rem);
    line-height: 1.65;
    letter-spacing: -0.012em;
  }

  .home-bio:last-of-type {
    margin-bottom: 1rem;
  }

  .cta-row {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.75rem;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 480px) {
    .cta-row {
      flex-direction: row;
      align-items: center;
    }
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-body);
    color: var(--color-accent-foreground);
    background: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-buttons);
    padding: 0.7rem 1rem;
    min-height: 3rem;
    box-sizing: border-box;
    text-decoration: none;
    font-weight: 500;
    box-shadow: var(--shadow-subtle);
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .cta-button:hover {
    color: var(--color-accent-foreground);
    filter: brightness(1.05);
    transform: translateY(-1px);
    box-shadow: var(--shadow-elevated);
  }

  .rss-link {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.5rem;
    min-height: 3rem;
    padding: 0.7rem 1rem;
    box-sizing: border-box;
    border-radius: var(--radius-buttons);
    color: var(--color-muted-foreground);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 450;
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .rss-link:hover {
    color: var(--color-foreground);
    background: var(--color-muted);
  }

  .rss-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .timeline-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-panels);
    background: var(--color-subtle);
    box-shadow: var(--shadow-subtle);
    margin-bottom: 4.5rem;
  }

  @media (min-width: 640px) {
    .timeline-section {
      grid-template-columns: 1fr 1fr;
      padding: 1.75rem;
    }
  }

  .timeline-group {
    margin-bottom: 0;
  }

  .timeline-group:last-child {
    margin-bottom: 0;
  }

  .timeline-label {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    font-weight: 550;
    letter-spacing: 0.1em;
    margin: 0 0 0.75rem;
  }

  .timeline-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-item {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-foreground);
    line-height: 1.55;
    margin-bottom: 0.6rem;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-role {
    font-weight: 450;
    color: var(--color-foreground);
  }

  .section-link {
    color: var(--color-foreground);
  }

  .home-socials {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-icon {
    color: var(--color-muted-foreground);
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    transition: color 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
  }

  .social-icon:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .social-icon:hover {
    color: var(--color-foreground);
    background: var(--color-muted);
    transform: translateY(-1px);
  }

  .recent-section {
    padding-top: 0;
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: var(--text-title);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin: 0 0 1.75rem;
  }

  .recent-posts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .recent-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.25rem;
    margin: 0 -1.25rem;
    border: 1px solid transparent;
    border-radius: var(--radius-cards);
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .recent-link:hover {
    border-color: var(--color-subtle-border);
    background: var(--color-subtle);
    transform: translateY(-1px);
  }

  .recent-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .recent-link:hover .recent-title {
    color: var(--color-foreground);
  }

  .recent-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-muted-foreground);
    line-height: 1.6;
  }

  .recent-date {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.125rem;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-decoration-color: var(--color-slate);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
    margin-top: 2rem;
  }

  .view-all-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .view-all-link:hover {
    color: var(--color-foreground);
    text-decoration-color: var(--color-muted-foreground);
  }
</style>
