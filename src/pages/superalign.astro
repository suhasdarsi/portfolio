  .shift{background:#1a1916;color:#fbfbf8;margin-top:120px;padding:92px 0}.section-head{display:flex;justify-content:space-between;border-bottom:1px solid #ded8cf;padding-bottom:16px;color:#c44b21}.section-head p{color:#77736b;margin:0}.section-head.light{border-color:#3a3833}.section-head.light p{color:#8d8981}.shift-grid{display:grid;grid-template-columns:1fr 1fr;gap:100px;padding-top:72px}.shift h2,.platform h2,.intelligence h2,.close h2{font-size:clamp(46px,5vw,76px)}.shift-copy>p,.platform-intro>p,.intel-grid>div>p{font-size:16px;line-height:1.65;color:#9b978e;max-width:500px;margin-top:30px}.flows{display:flex;flex-direction:column;gap:12px}.flow{border:1px solid #3d3a35;padding:26px}.flow.old{opacity:.55}.flow.new{background:#25231f;border-color:#4a453d}.tag{font:10px ui-monospace,monospace;text-transform:uppercase;letter-spacing:.1em;color:#969187}.flow-line{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;gap:12px;align-items:center;margin:24px 0 18px}.flow-line b{font-size:14px;text-align:center;border:1px solid #494641;padding:16px 8px}.flow-line .ai{border-color:#c44b21;color:#e37851}.flow-line i{font-style:normal;color:#c44b21}.flow small{color:#88847c}.principle{margin-top:16px;border-left:2px solid #c44b21;padding:4px 0 4px 24px}.principle span{font:10px ui-monospace,monospace;text-transform:uppercase;color:#c44b21}.principle p{font-family:Georgia,serif;font-size:22px;margin:10px 0 0}
