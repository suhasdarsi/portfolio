---
const products = [
  { code: '01', name: 'Surface', role: 'See', copy: 'An agentic endpoint sensor that discovers AI, carries telemetry and enforces policy on-device.' },
  { code: '02', name: 'Atlas', role: 'Understand', copy: 'Risk intelligence across 1,000,000+ AI assets, scored through capability, exposure and governance.' },
  { code: '03', name: 'Sentinel', role: 'Control', copy: 'Detection and response for AI interactions, with on-device verdicts in under 25 milliseconds.' },
  { code: '04', name: 'Signal', role: 'Remember', copy: 'A prompt-level system of record for investigation, evidence and durable audit trails.' },
  { code: '05', name: 'Console', role: 'Align', copy: 'The control plane for policy, investigation and reporting across the enterprise AI estate.' },
];

const dimensions = [
  ['Capability', 'What the asset can do and access'],
  ['Exposure', 'Its footprint across systems and users'],
  ['Governance', 'Its legal, compliance and policy posture'],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="SuperAlign alignment strategy — the cognitive security platform for the AI endpoint." />
    <title>SuperAlign — Alignment strategy</title>
  </head>
  <body>
    <header class="nav shell">
      <a class="brand" href="#top" aria-label="SuperAlign home">
        <svg viewBox="0 0 40 32" aria-hidden="true"><path d="M2 28 11 4l9 24H2Z"/><path d="m11 28 9-24 9 24H11Z"/><path d="m20 28 9-24 9 24H20Z"/></svg>
        <span>SuperAlign</span>
      </a>
      <div class="nav-meta"><span>Alignment strategy</span><span class="status"><i></i> 2026</span></div>
      <a class="nav-cta" href="https://cal.com/appidi">Book a briefing <span>↗</span></a>
    </header>

    <main id="top">
      <section class="hero shell">
        <div class="eyebrow">The cognitive security platform for the AI endpoint</div>
        <div class="hero-grid">
          <div>
            <h1>Bring enterprise AI<br/>into <em>alignment.</em></h1>
            <p class="lede">AI became the interface to everything. SuperAlign restores the visibility, context and control security teams lost along the way.</p>
            <div class="hero-actions">
              <a class="button solid" href="#strategy">Explore the strategy <span>↓</span></a>
              <a class="button" href="mailto:contact@superalign.ai">contact@superalign.ai <span>↗</span></a>
            </div>
          </div>
          <div class="alignment-field" aria-label="Three misaligned signals converging into one governed flow">
            <div class="field-label top">UNMANAGED AI</div>
            <svg viewBox="0 0 560 520" role="img">
              <defs><marker id="arrow" markerWidth="7" markerHeight="7" refX="5" refY="3.5" orient="auto"><path d="M0,0 L7,3.5 L0,7Z" fill="#c44b21"/></marker></defs>
              <path class="trace muted" d="M35 78 C180 78 125 194 270 235"/>
              <path class="trace muted" d="M35 244 C160 244 168 244 270 244"/>
              <path class="trace muted" d="M35 414 C175 414 132 300 270 253"/>
              <g class="loose one"><path d="M40 112 69 42l29 70H40Z"/><circle cx="69" cy="77" r="5"/></g>
              <g class="loose two"><path d="m33 276 42-62 20 73-62-11Z"/><circle cx="69" cy="257" r="5"/></g>
              <g class="loose three"><path d="m38 388 67 27-58 49-9-76Z"/><circle cx="66" cy="423" r="5"/></g>
              <circle class="boundary" cx="300" cy="244" r="72"/>
              <path class="mark" d="m245 277 27-70 28 70h-55Z"/><path class="mark hot" d="m272 277 28-70 28 70h-56Z"/><path class="mark" d="m300 277 28-70 27 70h-55Z"/>
              <path class="trace active" d="M373 244 H520" marker-end="url(#arrow)"/>
              <circle class="node" cx="411" cy="244" r="4"/><circle class="node" cx="452" cy="244" r="4"/><circle class="node" cx="493" cy="244" r="4"/>
              <text x="300" y="345" text-anchor="middle">POLICY BOUNDARY</text>
              <text x="450" y="224" text-anchor="middle">GOVERNED FLOW</text>
            </svg>
            <div class="field-note"><span>01</span> Many signals. One policy.</div>
          </div>
        </div>
        <div class="proof-strip">
          <div><strong>15 min</strong><span>Fleet-wide AI visibility</span></div>
          <div><strong>&lt;25 ms</strong><span>On-device verdict latency</span></div>
          <div><strong>1M+</strong><span>AI assets in Atlas</span></div>
          <div><strong>57</strong><span>Risk signal definitions</span></div>
        </div>
      </section>

      <section class="field-team shell">
        <div class="section-head"><span>01 / Brand identity</span><p>Meet the Field Team</p></div>
        <div class="team-intro">
          <div>
            <span class="team-kicker">Serious systems. Human stakes.</span>
            <h2>Security needs<br/>good <em>guides.</em></h2>
          </div>
          <p>The Field Team makes invisible AI infrastructure legible. Each operator is built from SuperAlign geometry, carries one terracotta tool and appears wherever the product needs to explain, orient or reassure.</p>
        </div>
        <div class="team-scene">
          <svg viewBox="0 0 1200 510" role="img" aria-label="The SuperAlign Field Team mapping and governing an AI system">
            <path class="scene-grid" d="M35 438H1165M120 438V170M410 438V95M775 438V145M1070 438V210"/>
            <path class="scene-signal" d="M135 224C255 168 308 263 408 204S603 124 756 211s224 12 340 72"/>
            <circle class="scene-node" cx="135" cy="224" r="5"/><circle class="scene-node" cx="408" cy="204" r="5"/><circle class="scene-node" cx="756" cy="211" r="5"/><circle class="scene-node" cx="1096" cy="283" r="5"/>

            <g class="person scout" transform="translate(92 114)">
              <path class="head" d="M58 0 92 70H24L58 0Z"/><path class="body" d="M18 102Q58 82 98 102L109 252H7L18 102Z"/>
              <path class="limb" d="M18 126-20 190M98 126l48 36M34 252l-12 86M82 252l18 86"/>
              <path class="tool-fill" d="m126 132 34 9-13 50-34-9 13-50Z"/><path class="tool-line" d="m132 132 6-22m-23 74-15 18"/>
              <path class="badge" d="m44 126 14-27 14 27H44Z"/>
            </g>
            <text class="scene-name" x="82" y="482">SCOUT / DISCOVERY</text>

            <g class="person mapper" transform="translate(505 120)">
              <path class="head" d="m64 0 34 70H30L64 0Z"/><path class="body" d="M20 101Q64 78 108 101l-8 151H28L20 101Z"/>
              <path class="limb" d="M25 128-24 174M103 128l45 50M45 252l-7 86M84 252l7 86"/>
              <path class="paper" d="M-57 159q44-23 88 0v78q-44-22-88 0v-78Zm88 0q44-23 88 0v78q-44-22-88 0v-78Z"/>
              <path class="tool-line" d="m-34 184 22-9 18 15m44-4 20 22 27-28"/><circle class="tool-fill" cx="70" cy="208" r="7"/>
              <path class="badge" d="m50 126 14-27 14 27H50Z"/>
            </g>
            <text class="scene-name" x="497" y="482">MAPPER / CONTEXT</text>

            <g class="person steward" transform="translate(922 108)">
              <path class="head" d="m62 0 34 70H28L62 0Z"/><path class="body" d="M18 102Q62 80 106 102l14 150H4L18 102Z"/>
              <path class="limb" d="M18 130-20 179M106 130l54 26M36 252l-13 86M89 252l13 86"/>
              <rect class="policy" x="124" y="105" width="72" height="92" rx="2"/><path class="tool-line" d="m139 129 11 10 26-27m-37 52h39"/>
              <path class="badge" d="m48 126 14-27 14 27H48Z"/>
            </g>
            <text class="scene-name" x="912" y="482">STEWARD / POLICY</text>
            <text class="scene-note" x="600" y="40" text-anchor="middle">ONE TEAM · ONE SYSTEM · ONE OUTCOME</text>
          </svg>
        </div>
        <div class="character-cards">
          <article><span>01</span><h3>Scout</h3><b>Finds what changed.</b><p>Appears in discovery, inventory and “new AI detected” moments.</p></article>
          <article><span>02</span><h3>Mapper</h3><b>Makes risk understandable.</b><p>Appears in Atlas, investigations and educational stories.</p></article>
          <article><span>03</span><h3>Steward</h3><b>Turns intent into policy.</b><p>Appears in enforcement, governance and executive reporting.</p></article>
          <aside><span>Visual rule 01</span><p>No faces. Personality comes from posture, tools and the problem being solved.</p></aside>
        </div>
      </section>

      <section class="shift" id="strategy">
        <div class="shell">
          <div class="section-head"><span>02 / The shift</span><p>AI changed the control point</p></div>
          <div class="shift-grid">
            <div class="shift-copy">
              <h2>The application<br/>no longer mediates<br/><em>access.</em></h2>
              <p>One prompt can reach many systems. One agent can use many tools. Security built around applications and network boundaries cannot see the entire interaction.</p>
            </div>
            <div class="flows">
              <div class="flow old"><span class="tag">Before AI</span><div class="flow-line"><b>User</b><i>→</i><b>Application</b><i>→</i><b>Data</b></div><small>The application was the control point.</small></div>
              <div class="flow new"><span class="tag">Now</span><div class="flow-line"><b>User</b><i>→</i><b class="ai">AI</b><i>→</i><b>Everything</b></div><small>AI is the interface layer. The endpoint is the new control point.</small></div>
              <div class="principle"><span>Alignment principle</span><p>Place governance where intent becomes action.</p></div>
            </div>
          </div>
        </div>
      </section>

      <section class="platform shell">
        <div class="section-head"><span>03 / The platform</span><p>One sensor. Three products. One console.</p></div>
        <div class="platform-intro"><h2>Every interaction,<br/>under one <em>policy.</em></h2><p>SuperAlign coordinates five components as one closed loop: discover the asset, understand the risk, make the decision, preserve the evidence and govern the fleet.</p></div>
        <div class="product-list">
          {products.map((product) => (
            <article class="product-row">
              <span class="product-code">{product.code}</span>
              <h3>SuperAlign {product.name}</h3>
              <span class="product-role">{product.role}</span>
              <p>{product.copy}</p>
              <span class="product-mark" aria-hidden="true"></span>
            </article>
          ))}
        </div>
      </section>

      <section class="intelligence">
        <div class="shell">
          <div class="section-head light"><span>04 / Risk intelligence</span><p>Context before control</p></div>
          <div class="intel-grid">
            <div><h2>A score that explains<br/>the <em>decision.</em></h2><p>Atlas evaluates every AI asset across three business-readable dimensions, producing a CVSS-aligned score from 0–10.</p></div>
            <div class="score-card">
              <div class="score-top"><span>AIRS / ASSET 048392</span><strong>8.7</strong><small>HIGH RISK</small></div>
              <div class="dimensions">
                {dimensions.map(([name, copy], i) => (<div><span>0{i + 1}</span><b>{name}</b><p>{copy}</p></div>))}
              </div>
              <div class="scale"><span>LOW</span><i></i><i></i><i></i><i class="current"></i><span>CRITICAL</span></div>
            </div>
          </div>
          <div class="frameworks"><span>Aligned to</span><p>EU AI Act · ISO 42001 · NIST AI RMF · MITRE ATLAS · OWASP LLM, Agent, MCP &amp; Skill Top 10</p></div>
        </div>
      </section>

      <section class="close shell">
        <span class="close-kicker">The alignment strategy</span>
        <h2>See every interaction.<br/>Understand every risk.<br/><em>Control every outcome.</em></h2>
        <div class="close-bottom"><p>Security for AI should feel less like surveillance and more like a well-governed system: visible, explainable and precise.</p><a class="button solid" href="https://cal.com/appidi">Start a conversation <span>↗</span></a></div>
      </section>
    </main>

    <footer class="shell"><span>SuperAlign · Confidential · 2026</span><div><a href="mailto:contact@superalign.ai">contact@superalign.ai</a><a href="https://superalign.ai">superalign.ai</a></div></footer>
  </body>
</html>

