---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import Backlinks from '../../components/Backlinks.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import SearchData from '../../components/SearchData.astro';
import MaturityBadge from '../../components/MaturityBadge.astro';
import { formatDateWithYear, getReadingTime } from '../../utils/date';

export async function getStaticPaths() {
	const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
const readingTime = getReadingTime(post.body ?? '');

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
---

<BlogLayout title={`${post.data.title} | Suhas Darsi`} description={post.data.description}>
  <SearchData />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    ...(post.data.updatedDate ? { "dateModified": post.data.updatedDate.toISOString() } : {}),
    "author": { "@type": "Person", "name": "Suhas Darsi" },
    "url": `https://suhasdarsi.com/notes/${post.id}`
  })} />
  <article>
    <a href="/notes" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5"></path>
        <path d="m12 19-7-7 7-7"></path>
      </svg>
      Back to Notes
    </a>
    
    <header class="article-header">
      <div class="article-meta-top">
        <MaturityBadge maturity={post.data.maturity} />
        {post.data.topics.length > 0 && (
          <div class="article-topics">
            {post.data.topics.map((topic) => (
              <a href={`/notes?topic=${topic}`} class="topic-tag">{topic}</a>
            ))}
          </div>
        )}
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="article-meta">
        <div class="article-date">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
            <line x1="16" x2="16" y1="2" y2="6"></line>
            <line x1="8" x2="8" y1="2" y2="6"></line>
            <line x1="3" x2="21" y1="10" y2="10"></line>
          </svg>
          <time datetime={post.data.pubDate.toISOString()}>{formatDateWithYear(post.data.pubDate)}</time>
        </div>
        {post.data.updatedDate && (
          <div class="article-date">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              <polyline points="21 3 21 9 15 9"/>
            </svg>
            Updated <time datetime={post.data.updatedDate.toISOString()}>{formatDateWithYear(post.data.updatedDate)}</time>
          </div>
        )}
        <div class="article-reading-time">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {readingTime} min read
        </div>
      </div>
    </header>

    <TableOfContents />

    <div class="prose-custom">
      <Content />
    </div>

    <Backlinks currentSlug={post.id} />

    {(prevPost || nextPost) && (
      <nav class="note-nav">
        {prevPost ? (
          <a href={`/notes/${prevPost.id}`} class="note-nav-link note-nav-prev">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            <div class="note-nav-content">
              <span class="note-nav-label">Previous</span>
              <span class="note-nav-title">{prevPost.data.title}</span>
            </div>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/notes/${nextPost.id}`} class="note-nav-link note-nav-next">
            <div class="note-nav-content">
              <span class="note-nav-label">Next</span>
              <span class="note-nav-title">{nextPost.data.title}</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
        ) : <div />}
      </nav>
    )}
  </article>
</BlogLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    font-size: var(--text-body);
    margin-bottom: 2.5rem;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .back-link:hover {
    color: var(--color-foreground);
    gap: 0.5rem;
  }

  .back-link svg {
    transition: transform 0.3s ease;
  }

  .back-link:hover svg {
    transform: translateX(-3px);
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .article-topics {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .topic-tag {
    font-size: var(--text-caption);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    color: var(--color-muted-foreground);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .topic-tag:hover {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .article-title {
    font-size: var(--text-display-sm);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .article-title {
      font-size: var(--text-display);
    }
  }

  .article-description {
    font-size: var(--text-body-lg);
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .article-date,
  .article-reading-time {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
  }

  .article-date svg,
  .article-reading-time svg {
    opacity: 0.5;
  }

  .note-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-subtle-border);
  }

  .note-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .note-nav-link:hover {
    border-color: var(--color-foreground);
  }

  .note-nav-prev {
    justify-content: flex-start;
  }

  .note-nav-next {
    justify-content: flex-end;
    text-align: right;
  }

  .note-nav-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .note-nav-label {
    font-size: var(--text-caption);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .note-nav-title {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  .note-nav-link:hover .note-nav-title {
    color: var(--color-muted-foreground);
  }

  .note-nav-link svg {
    color: var(--color-muted-foreground);
    flex-shrink: 0;
  }
</style>
