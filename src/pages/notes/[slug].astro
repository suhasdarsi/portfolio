---
import { render } from 'astro:content';
import {
  getCardsForSource,
  getPublishedBlogEntries,
  getPublishedBlogEntriesByDate,
  getPublishedCardEntries,
  validatePublishedCardReferences,
} from '../../utils/content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import Backlinks from '../../components/Backlinks.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import CopyCode from '../../components/CopyCode.astro';
import { formatDateWithYear, getReadingTime } from '../../utils/date';

export async function getStaticPaths() {
	await validatePublishedCardReferences();
	const posts = await getPublishedBlogEntries();
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
const readingTime = getReadingTime(post.body || '');

const allPosts = await getPublishedBlogEntriesByDate();
const sourceCards = getCardsForSource(post.id, await getPublishedCardEntries());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://suhasdarsi.com';
const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  ...(post.data.updatedDate ? { "dateModified": post.data.updatedDate.toISOString() } : {}),
  "author": { "@type": "Person", "name": "Suhas Darsi" },
  "url": `${siteUrl}/notes/${post.id}`
}).replace(/</g, '\\u003c');
---

<BlogLayout title={`${post.data.title} | Suhas Darsi`} description={post.data.description} ogType="article">
  <ReadingProgress />
  <CopyCode />
  <script type="application/ld+json" set:html={structuredData} />
  <article>
    <header class="article-header">
      <a href="/notes" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Notes
      </a>
      {post.data.topics.length > 0 && (
        <div class="article-topics">
          {post.data.topics.map((topic) => (
            <a href={`/notes?topic=${encodeURIComponent(topic)}`} class="topic-tag">{topic}</a>
          ))}
        </div>
      )}
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="article-meta">
        <div class="article-date">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
            <line x1="16" x2="16" y1="2" y2="6"></line>
            <line x1="8" x2="8" y1="2" y2="6"></line>
            <line x1="3" x2="21" y1="10" y2="10"></line>
          </svg>
          <time datetime={post.data.pubDate.toISOString()}>{formatDateWithYear(post.data.pubDate)}</time>
        </div>
        {post.data.updatedDate && (
          <div class="article-date">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              <polyline points="21 3 21 9 15 9"/>
            </svg>
            Updated <time datetime={post.data.updatedDate.toISOString()}>{formatDateWithYear(post.data.updatedDate)}</time>
          </div>
        )}
        {readingTime && <span class="article-reading-time">{readingTime}</span>}
      </div>
    </header>

    <div class="prose-custom">
      <Content />
    </div>

    {sourceCards.length > 0 && (
      <section class="source-cards" aria-labelledby="source-cards-title">
        <div class="section-heading">
          <h2 id="source-cards-title">Ideas from this essay</h2>
          <span>{sourceCards.length} short-form {sourceCards.length === 1 ? 'card' : 'cards'}</span>
        </div>
        <div class="source-cards-list">
          {sourceCards.map((card) => (
            <a href={`/cards/${card.id}`}>
              <span>{card.data.topic}</span>
              <strong>{card.data.title}</strong>
              <small>{card.data.description}</small>
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"></path>
                <path d="m13 6 6 6-6 6"></path>
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <Backlinks currentSlug={post.id} />

    {(prevPost || nextPost) && (
      <nav class="note-nav">
        {prevPost ? (
          <a href={`/notes/${prevPost.id}`} class="note-nav-link note-nav-prev">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            <div class="note-nav-content">
              <span class="note-nav-label">Previous</span>
              <span class="note-nav-title">{prevPost.data.title}</span>
            </div>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/notes/${nextPost.id}`} class="note-nav-link note-nav-next">
            <div class="note-nav-content">
              <span class="note-nav-label">Next</span>
              <span class="note-nav-title">{nextPost.data.title}</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
        ) : <div />}
      </nav>
    )}
  </article>
</BlogLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 550;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }

  .back-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .back-link:hover {
    color: var(--color-foreground);
  }

  .back-link svg {
    transition: transform 0.2s ease;
  }

  .back-link:hover svg {
    transform: translateX(-2px);
  }

  .article-header {
    margin-bottom: 3.25rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-subtle-border);
  }

  .article-topics {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .article-title {
    font-size: clamp(2.35rem, 7vw, 3.6rem);
    line-height: 1.07;
    letter-spacing: -0.04em;
    margin-bottom: 1.25rem;
    text-wrap: balance;
    font-weight: 550;
  }

  @media (min-width: 768px) {
    .article-title {
      font-size: clamp(3rem, 5vw, 3.6rem);
    }
  }

  .article-description {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 2.5vw, 1.2rem);
    color: var(--color-body-text);
    line-height: 1.62;
    margin-bottom: 1.75rem;
    text-wrap: pretty;
  }

  .article-meta {
    font-family: var(--font-sans);
    display: flex;
    align-items: center;
    gap: 0.625rem 1.25rem;
    flex-wrap: wrap;
  }

  .article-date {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-muted-foreground);
  }

  .article-date svg {
    opacity: 0.5;
  }

  .article-reading-time {
    font-size: 0.8125rem;
    color: var(--color-muted-foreground);
  }

  .source-cards {
    margin-top: 3.5rem;
    padding: 1.25rem;
    border-radius: 16px;
    background: var(--color-subtle);
    box-shadow: inset 0 0 0 1px var(--color-subtle-border);
    font-family: var(--font-sans);
  }

  .section-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .section-heading h2 {
    margin: 0;
    color: var(--color-muted-foreground);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 450;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-heading > span {
    color: var(--color-muted-foreground);
    font-size: 0.7rem;
  }

  .source-cards-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .source-cards-list a {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.2rem 0.75rem;
    padding: 0.85rem;
    border-radius: 10px;
    color: var(--color-foreground);
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .source-cards-list a:hover {
    background: var(--color-muted);
  }

  .source-cards-list a > span,
  .source-cards-list a > small {
    grid-column: 1;
    color: var(--color-muted-foreground);
  }

  .source-cards-list a > span {
    font-size: 0.68rem;
  }

  .source-cards-list a > strong {
    grid-column: 1;
    font-size: 0.86rem;
    font-weight: 550;
    line-height: 1.4;
  }

  .source-cards-list a > small {
    margin-top: 0.1rem;
    font-size: 0.74rem;
    line-height: 1.45;
  }

  .source-cards-list svg {
    grid-column: 2;
    grid-row: 1 / span 3;
    align-self: center;
    color: var(--color-muted-foreground);
  }

  .note-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.45rem;
    margin-top: 1rem;
    padding: 1.25rem;
    border-radius: 16px;
    background: var(--color-subtle);
    box-shadow: inset 0 0 0 1px var(--color-subtle-border);
  }

  .note-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem;
    border: 0;
    border-radius: 10px;
    background: transparent;
    box-shadow: none;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.2s ease;
  }

  .note-nav-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .note-nav-link:hover {
    background: var(--color-muted);
  }

  .note-nav-prev {
    justify-content: flex-start;
  }

  .note-nav-next {
    justify-content: flex-end;
    text-align: right;
  }

  .note-nav-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .note-nav-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .note-nav-title {
    font-family: var(--font-sans);
    font-size: 0.84rem;
    font-weight: 540;
    line-height: 1.45;
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  .note-nav-link:hover .note-nav-title {
    color: var(--color-foreground);
  }

  .note-nav-link svg {
    color: var(--color-muted-foreground);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .back-link {
      margin-bottom: 1rem;
    }

    .article-header {
      margin-bottom: 2rem;
    }

    .article-meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.5rem;
    }

    .source-cards {
      margin-top: 2.5rem;
    }

    .source-cards-list {
      grid-template-columns: 1fr;
    }

    .note-nav {
      grid-template-columns: 1fr;
    }

    .note-nav-next {
      text-align: left;
      justify-content: flex-start;
    }
  }
</style>
