---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import Backlinks from '../../components/Backlinks.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import CopyCode from '../../components/CopyCode.astro';
import { formatDateWithYear, getReadingTime } from '../../utils/date';

export async function getStaticPaths() {
	const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
const readingTime = getReadingTime(post.body || '');

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://suhasdarsi.com';
const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  ...(post.data.updatedDate ? { "dateModified": post.data.updatedDate.toISOString() } : {}),
  "author": { "@type": "Person", "name": "Suhas Darsi" },
  "url": `${siteUrl}/notes/${post.id}`
}).replace(/</g, '\\u003c');
---

<BlogLayout title={`${post.data.title} | Suhas Darsi`} description={post.data.description} ogType="article">
  <ReadingProgress />
  <CopyCode />
  <script type="application/ld+json" set:html={structuredData} />
  <article>
    <header class="article-header">
      <a href="/notes" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Notes
      </a>
      {post.data.topics.length > 0 && (
        <div class="article-topics">
          {post.data.topics.map((topic) => (
            <a href={`/notes?topic=${encodeURIComponent(topic)}`} class="topic-tag">{topic}</a>
          ))}
        </div>
      )}
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="article-meta">
        <div class="article-date">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
            <line x1="16" x2="16" y1="2" y2="6"></line>
            <line x1="8" x2="8" y1="2" y2="6"></line>
            <line x1="3" x2="21" y1="10" y2="10"></line>
          </svg>
          <time datetime={post.data.pubDate.toISOString()}>{formatDateWithYear(post.data.pubDate)}</time>
        </div>
        {post.data.updatedDate && (
          <div class="article-date">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              <polyline points="21 3 21 9 15 9"/>
            </svg>
            Updated <time datetime={post.data.updatedDate.toISOString()}>{formatDateWithYear(post.data.updatedDate)}</time>
          </div>
        )}
        {readingTime && <span class="article-reading-time">{readingTime}</span>}
      </div>
    </header>

    <div class="prose-custom">
      <Content />
    </div>

    <Backlinks currentSlug={post.id} />

    {(prevPost || nextPost) && (
      <nav class="note-nav">
        {prevPost ? (
          <a href={`/notes/${prevPost.id}`} class="note-nav-link note-nav-prev">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            <div class="note-nav-content">
              <span class="note-nav-label">Previous</span>
              <span class="note-nav-title">{prevPost.data.title}</span>
            </div>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/notes/${nextPost.id}`} class="note-nav-link note-nav-next">
            <div class="note-nav-content">
              <span class="note-nav-label">Next</span>
              <span class="note-nav-title">{nextPost.data.title}</span>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
        ) : <div />}
      </nav>
    )}
  </article>
</BlogLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    font-size: var(--text-small);
    margin-bottom: 1.5rem;
    transition: color 0.2s ease;
  }

  .back-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .back-link:hover {
    color: var(--color-foreground);
  }

  .back-link svg {
    transition: transform 0.2s ease;
  }

  .back-link:hover svg {
    transform: translateX(-2px);
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-topics {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .article-title {
    font-size: clamp(2rem, 7vw, var(--text-display));
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
    text-wrap: balance;
    font-weight: 500;
  }

  @media (min-width: 768px) {
    .article-title {
      font-size: var(--text-display);
    }
  }

  .article-description {
    font-family: var(--font-serif);
    font-size: var(--text-subtitle);
    color: var(--color-body-text);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    text-wrap: pretty;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem 1.25rem;
    flex-wrap: wrap;
  }

  .article-date {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
  }

  .article-date svg {
    opacity: 0.5;
  }

  .article-reading-time {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
  }

  .note-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-subtle-border);
  }

  .note-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-cards);
    background: var(--color-subtle);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .note-nav-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .note-nav-link:hover {
    border-color: var(--color-muted-foreground);
    background: var(--color-muted);
  }

  .note-nav-prev {
    justify-content: flex-start;
  }

  .note-nav-next {
    justify-content: flex-end;
    text-align: right;
  }

  .note-nav-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .note-nav-label {
    font-size: var(--text-caption);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .note-nav-title {
    font-size: var(--text-body);
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  .note-nav-link:hover .note-nav-title {
    color: var(--color-muted-foreground);
  }

  .note-nav-link svg {
    color: var(--color-muted-foreground);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .back-link {
      margin-bottom: 1rem;
    }

    .article-header {
      margin-bottom: 2rem;
    }

    .article-meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.5rem;
    }

    .note-nav {
      grid-template-columns: 1fr;
    }

    .note-nav-next {
      text-align: left;
      justify-content: flex-start;
    }
  }
</style>
