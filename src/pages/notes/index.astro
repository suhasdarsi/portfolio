---
import { getPublishedBlogEntriesByDate } from '../../utils/content';
import { formatDate } from '../../utils/date';

import BlogLayout from '../../layouts/BlogLayout.astro';

const posts = await getPublishedBlogEntriesByDate();
const allTopicsUsed = [...new Set(posts.flatMap((p) => p.data.topics))].sort();
---

<BlogLayout title="AI Security Notes | Suhas Darsi" description="Practical field notes on AI security, agent systems, and network risk.">
  <div class="notes-header">
    <div class="notes-header-top">
      <div>
        <p class="notes-kicker">AI security field notes</p>
        <h1 class="notes-heading">AI Security</h1>
        <p class="notes-intro">Practical essays on how AI systems fail, how attacks propagate through connected agents, and how builders can contain the risk.</p>
      </div>
    </div>
    {allTopicsUsed.length > 1 && (
      <div class="topic-filters" id="topic-filters">
        <button type="button" class="topic-filter active" data-topic="all" aria-pressed="true">All</button>
        {allTopicsUsed.map((topic) => (
          <button type="button" class="topic-filter" data-topic={topic} aria-pressed="false">{topic}</button>
        ))}
      </div>
    )}
  </div>

  <div class="note-list" id="note-list">
    {posts.map((post) => (
      <article
        class="note-item"
        data-searchable
        data-post-id={post.id}
        data-topics={JSON.stringify(post.data.topics)}
      >
        <a href={`/notes/${post.id}`} class="note-link">
          <div class="note-meta-top">
            {post.data.topics.length > 0 && (
              <div class="note-topics">
                {post.data.topics.map((topic) => (
                  <span class="topic-tag">{topic}</span>
                ))}
              </div>
            )}
          </div>
          <h2 class="note-title">
            {post.data.title}
          </h2>
          <p class="note-desc">
            {post.data.description}
          </p>
          <div class="note-meta">
            <div class="note-date">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
          </div>
        </a>
      </article>
    ))}
    <p class="search-empty hidden" id="search-empty">No notes found.</p>
  </div>
</BlogLayout>

<script>
  const articles = document.querySelectorAll('[data-searchable]');
  const emptyMsg = document.getElementById('search-empty');
  const topicFilters = document.getElementById('topic-filters');

  let activeTopic = 'all';

  const urlParams = new URLSearchParams(window.location.search);
  const topicFromUrl = urlParams.get('topic');
  const availableTopics = topicFilters
    ? Array.from(topicFilters.querySelectorAll<HTMLElement>('.topic-filter')).map((button) => button.dataset.topic)
    : [];
  if (topicFromUrl && availableTopics.includes(topicFromUrl) && topicFilters) {
    activeTopic = topicFromUrl;
    topicFilters.querySelectorAll('.topic-filter').forEach((b) => {
      const isActive = b.getAttribute('data-topic') === activeTopic;
      b.classList.toggle('active', isActive);
      b.setAttribute('aria-pressed', String(isActive));
    });
  }

  function applyFilters() {
    let visibleCount = 0;

    articles.forEach((el) => {
      const topics = JSON.parse(el.getAttribute('data-topics') || '[]') as string[];
      const matchesTopic = activeTopic === 'all' || topics.includes(activeTopic);

      if (matchesTopic) {
        el.classList.remove('hidden');
        visibleCount++;
      } else {
        el.classList.add('hidden');
      }
    });

    if (emptyMsg) {
      emptyMsg.classList.toggle('hidden', visibleCount > 0);
    }

  }

  const handleTopicClick = (e: Event) => {
    const btn = (e.target as HTMLElement).closest('.topic-filter');
    if (!btn) return;

    activeTopic = btn.getAttribute('data-topic') || 'all';
    topicFilters?.querySelectorAll('.topic-filter').forEach((b) => {
      const isActive = b.getAttribute('data-topic') === activeTopic;
      b.classList.toggle('active', isActive);
      b.setAttribute('aria-pressed', String(isActive));
    });
    applyFilters();
  };

  topicFilters?.addEventListener('click', handleTopicClick);

  applyFilters();

  window.addEventListener('beforeunload', () => {
    topicFilters?.removeEventListener('click', handleTopicClick);
  });
</script>

<style>
  .notes-header {
    margin-bottom: 2.75rem;
  }

  .notes-header-top {
    display: flex;
    align-items: center;
    margin-bottom: 2rem;
  }

  .notes-heading {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.035em;
    line-height: 1.08;
    margin: 0 0 0.85rem;
  }

  .notes-kicker {
    margin: 0 0 0.65rem;
    color: var(--color-muted-foreground);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 520;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .notes-intro {
    max-width: 38rem;
    margin: 0;
    color: var(--color-muted-foreground);
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.65;
    text-wrap: pretty;
  }

  @media (min-width: 768px) {
    .notes-heading {
      font-size: var(--text-display);
    }
  }

  .topic-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .topic-filter {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.25rem;
    font-weight: 500;
    padding: 0.45rem 0.8rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--color-muted);
    color: var(--color-muted-foreground);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .topic-filter:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .topic-filter:hover {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .topic-filter.active {
    background: var(--color-accent);
    color: var(--color-accent-foreground);
    border-color: var(--color-accent);
  }

  .note-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .note-item {
    padding: 0;
    border: 0;
  }

  .note-item:last-child {
    padding-bottom: 0;
  }

  .note-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.5rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-cards);
    background: var(--color-subtle);
    box-shadow: var(--shadow-subtle);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .note-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .note-link:hover {
    color: var(--color-foreground);
    border-color: color-mix(in srgb, var(--color-accent) 52%, var(--color-subtle-border));
    transform: translateY(-2px);
    box-shadow: var(--shadow-elevated);
  }

  .note-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .note-topics {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .note-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    font-weight: 550;
    line-height: 1.28;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .note-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-body-text);
    line-height: 1.6;
    margin: 0 0 0.5rem;
  }

  .note-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .note-date {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .search-empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-muted-foreground);
    padding: 2rem 0;
    text-align: center;
  }</style>
