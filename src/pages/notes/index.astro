---
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';
import BlogLayout from '../../layouts/BlogLayout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const allTopicsUsed = [...new Set(posts.flatMap((p) => p.data.topics))].sort();
---

<BlogLayout title="Notes | Suhas Darsi" description="My digital garden - thoughts on AI safety, product, bags, travel, and infrastructure.">
  <div class="notes-header">
    <div class="notes-header-top">
      <h1 class="notes-heading">Notes</h1>
    </div>
    {allTopicsUsed.length > 0 && (
      <div class="topic-filters" id="topic-filters">
        <button type="button" class="topic-filter active" data-topic="all">All</button>
        {allTopicsUsed.map((topic) => (
          <button type="button" class="topic-filter" data-topic={topic}>{topic}</button>
        ))}
      </div>
    )}
    <div class="notes-controls">
      <input type="text" id="notes-search" class="notes-search-input" placeholder="Filter by title or description..." autocomplete="off" />
      <span class="notes-count" id="notes-count"></span>
    </div>

  <div class="note-list" id="note-list">
    {posts.map((post) => (
      <article
        class="note-item"
        data-searchable
        data-post-id={post.id}
        data-topics={JSON.stringify(post.data.topics)}
      >
        <a href={`/notes/${post.id}`} class="note-link">
          <div class="note-meta-top">
            {post.data.topics.length > 0 && (
              <div class="note-topics">
                {post.data.topics.map((topic) => (
                  <span class="topic-tag">{topic}</span>
                ))}
              </div>
            )}
          </div>
          <h2 class="note-title">
            {post.data.title}
          </h2>
          <p class="note-desc">
            {post.data.description}
          </p>
          <div class="note-meta">
            <div class="note-date">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
          </div>
        </a>
      </article>
    ))}
    <p class="search-empty hidden" id="search-empty">No notes found.</p>
  </div>
</BlogLayout>

<script>
  const articles = document.querySelectorAll('[data-searchable]');
  const emptyMsg = document.getElementById('search-empty');
  const topicFilters = document.getElementById('topic-filters');
  const searchInput = document.getElementById('notes-search') as HTMLInputElement;
  const countDisplay = document.getElementById('notes-count');
  const totalCount = articles.length;

  let activeTopic = 'all';
  let searchQuery = '';

  const urlParams = new URLSearchParams(window.location.search);
  const topicFromUrl = urlParams.get('topic');
  if (topicFromUrl && topicFilters) {
    activeTopic = topicFromUrl;
    topicFilters.querySelectorAll('.topic-filter').forEach((b) => {
      b.classList.toggle('active', b.getAttribute('data-topic') === activeTopic);
    });
  }

  function applyFilters() {
    let visibleCount = 0;

    articles.forEach((el) => {
      const title = el.querySelector('.note-title')?.textContent?.toLowerCase() || '';
      const desc = el.querySelector('.note-desc')?.textContent?.toLowerCase() || '';
      const topics = JSON.parse(el.getAttribute('data-topics') || '[]') as string[];
      const matchesTopic = activeTopic === 'all' || topics.includes(activeTopic);
      const matchesSearch = !searchQuery || title.includes(searchQuery) || desc.includes(searchQuery);

      if (matchesTopic && matchesSearch) {
        el.classList.remove('hidden');
        visibleCount++;
      } else {
        el.classList.add('hidden');
      }
    });

    if (emptyMsg) {
      emptyMsg.classList.toggle('hidden', visibleCount > 0);
    }

    if (countDisplay) {
      const label = activeTopic !== 'all' ? `Filtered: ` : '';
      countDisplay.textContent = visibleCount < totalCount ? `${label}${visibleCount} of ${totalCount}` : `${totalCount} notes`;
    }
  }

  const handleTopicClick = (e: Event) => {
    const btn = (e.target as HTMLElement).closest('.topic-filter');
    if (!btn) return;

    activeTopic = btn.getAttribute('data-topic') || 'all';
    topicFilters?.querySelectorAll('.topic-filter').forEach((b) => {
      b.classList.toggle('active', b.getAttribute('data-topic') === activeTopic);
    });
    applyFilters();
  };

  topicFilters?.addEventListener('click', handleTopicClick);

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    applyFilters();
  });

  applyFilters();

  window.addEventListener('beforeunload', () => {
    topicFilters?.removeEventListener('click', handleTopicClick);
  });
</script>

<style>
  .notes-header {
    margin-bottom: 2rem;
  }

  .notes-header-top {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .notes-heading {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: 0;
    margin: 0;
  }

  @media (min-width: 768px) {
    .notes-heading {
      font-size: var(--text-display);
    }
  }

  .topic-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .topic-filter {
    font-size: 0.875rem;
    line-height: 1.25rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-subtle-border);
    background: var(--color-subtle);
    color: var(--color-muted-foreground);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .topic-filter:hover {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .notes-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .notes-search-input {
    flex: 1;
    max-width: 28rem;
    font-family: var(--font-serif);
    font-size: 0.875rem;
    color: var(--color-foreground);
    background: none;
    border: 1px solid var(--color-subtle-border);
    padding: 0.5rem 0.75rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .notes-search-input::placeholder {
    color: var(--color-muted-foreground);
  }

  .notes-search-input:focus {
    border-color: var(--color-foreground);
  }

  .notes-count {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    white-space: nowrap;
  }

  .topic-filter.active {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .note-list {
    display: flex;
    flex-direction: column;
  }

  .note-item {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-subtle-border);
  }

  .note-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .note-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .note-link:hover {
    color: var(--color-muted-foreground);
  }

  .note-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .note-topics {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .note-title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: 0;
    margin: 0 0 0.5rem;
  }

  .note-desc {
    font-size: 1rem;
    color: var(--color-body-text);
    line-height: 1.6;
    margin: 0 0 0.5rem;
  }

  .note-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .note-date {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .search-empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-muted-foreground);
    padding: 2rem 0;
    text-align: center;
  }</style>
