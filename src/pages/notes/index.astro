---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';
import MaturityBadge from '../../components/MaturityBadge.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const allTopicsUsed = [...new Set(posts.flatMap((p) => p.data.topics))].sort();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Astro" />
    <meta name="description" content="My digital garden - thoughts on AI safety, product, bags, travel, and infrastructure." />
    <meta name="author" content="Suhas Darsi" />
    <title>Notes | Suhas Darsi</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background">
    <Header />

    <main class="max-w-3xl mx-auto px-6 py-8">
      <div class="notes-header">
        <div class="notes-header-top">
          <h1 class="notes-heading">Notes</h1>
        </div>
        {allTopicsUsed.length > 0 && (
          <div class="topic-filters" id="topic-filters">
            <button type="button" class="topic-filter active" data-topic="all">All</button>
            {allTopicsUsed.map((topic) => (
              <button type="button" class="topic-filter" data-topic={topic}>{topic}</button>
            ))}
          </div>
        )}
      </div>

      <div class="note-list" id="note-list">
        {posts.map((post) => (
          <article
            class="note-item"
            data-searchable
            data-post-id={post.id}
            data-topics={JSON.stringify(post.data.topics)}
          >
            <a href={`/notes/${post.id}`} class="note-link">
              <div class="note-meta-top">
                <MaturityBadge maturity={post.data.maturity} />
                {post.data.topics.length > 0 && (
                  <div class="note-topics">
                    {post.data.topics.map((topic) => (
                      <span class="topic-tag">{topic}</span>
                    ))}
                  </div>
                )}
              </div>
              <h2 class="note-title">
                {post.data.title}
              </h2>
              <p class="note-desc">
                {post.data.description}
              </p>
              <div class="note-meta">
                <div class="note-date">
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
      <p class="search-empty hidden" id="search-empty">No notes found.</p>
    </main>

    <Footer />
  </body>
</html>

<script>
  const articles = document.querySelectorAll('[data-searchable]');
  const emptyMsg = document.getElementById('search-empty');
  const topicFilters = document.getElementById('topic-filters');

  let activeTopic = 'all';

  const urlParams = new URLSearchParams(window.location.search);
  const topicFromUrl = urlParams.get('topic');
  if (topicFromUrl && topicFilters) {
    activeTopic = topicFromUrl;
    topicFilters.querySelectorAll('.topic-filter').forEach((b) => {
      b.classList.toggle('active', b.getAttribute('data-topic') === activeTopic);
    });
  }

  function applyFilters() {
    let visibleCount = 0;

    articles.forEach((el) => {
      const id = el.getAttribute('data-post-id');
      const topics = JSON.parse(el.getAttribute('data-topics') || '[]') as string[];
      const matchesTopic = activeTopic === 'all' || topics.includes(activeTopic);
      const matchesSearch = Boolean(id);

      if (matchesTopic && matchesSearch) {
        el.classList.remove('hidden');
        visibleCount++;
      } else {
        el.classList.add('hidden');
      }
    });

    if (emptyMsg) {
      if (visibleCount === 0) emptyMsg.classList.remove('hidden');
      else emptyMsg.classList.add('hidden');
    }
  }

  topicFilters?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.topic-filter');
    if (!btn) return;

    activeTopic = btn.getAttribute('data-topic') || 'all';
    topicFilters.querySelectorAll('.topic-filter').forEach((b) => {
      b.classList.toggle('active', b.getAttribute('data-topic') === activeTopic);
    });
    applyFilters();
  });

  applyFilters();
</script>

<style>
  .notes-header {
    margin-bottom: 2rem;
  }

  .notes-header-top {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .notes-heading {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.02em;
    margin: 0;
  }

  @media (min-width: 768px) {
    .notes-heading {
      font-size: var(--text-display);
    }
  }

  .topic-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .topic-filter {
    font-size: var(--text-small);
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    background: none;
    color: var(--color-muted-foreground);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .topic-filter:hover {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .topic-filter.active {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .note-list {
    display: flex;
    flex-direction: column;
  }

  .note-item {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-subtle-border);
  }

  .note-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .note-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .note-link:hover {
    color: var(--color-muted-foreground);
  }

  .note-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .note-topics {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .topic-tag {
    font-size: var(--text-caption);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    color: var(--color-muted-foreground);
  }

  .note-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  .note-desc {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin: 0 0 0.5rem;
  }

  .note-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .note-date {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .search-empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-muted-foreground);
    padding: 2rem 0;
    text-align: center;
  }

  .hidden {
    display: none !important;
  }

</style>
