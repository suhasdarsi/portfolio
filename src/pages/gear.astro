---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://suhasdarsi.com';

const categories = [
  {
    name: 'Tech',
    items: [
      {
        name: 'Mac Mini M4',
        description: 'Primary desktop. Compact, powerful, and runs everything I need.',
        url: 'https://www.apple.com/mac-mini/',
      },
      {
        name: 'iPad Pro M4 11"',
        description: 'Portable workstation with Magic Keyboard. Great for reading and light work on the go.',
        url: 'https://www.apple.com/ipad-pro/',
      },
      {
        name: 'iPhone 15',
        description: 'Daily driver. Does the job without fuss.',
        url: 'https://www.apple.com/iphone-15/',
      },
      {
        name: 'AirPods Pro 2',
        description: 'Everyday earbuds. Noise cancellation that actually works.',
        url: 'https://www.apple.com/airpods-pro/',
      },
      {
        name: 'Amazfit Helio Band',
        description: 'Fitness tracking without the smartwatch bloat.',
        url: 'https://www.amazfit.com',
      },
    ],
  },
  {
    name: 'Workspace',
    items: [
      {
        name: 'Keychron K8 Pro',
        description: 'Mechanical keyboard. Hot-swappable, wireless, and satisfying to type on.',
        url: 'https://www.keychron.com/products/keychron-k8-pro',
      },
      {
        name: 'Damoshark M3',
        description: 'Mouse. Lightweight and precise.',
        url: 'https://www.damoshark.com',
      },
      {
        name: 'HyperX SoloCast',
        description: 'Microphone. Clean audio for calls and recordings without the setup hassle.',
        url: 'https://www.hyperx.com/products/hyperx-solocast-usb-microphone',
      },
    ],
  },
  {
    name: 'Travel',
    items: [
      {
        name: 'INUI 10,000mAh 45W Powerbank',
        description: 'Compact enough for daily carry, powerful enough to charge a laptop.',
        url: 'https://www.inui.tech',
      },
      {
        name: 'Owala FreeSip 945ml',
        description: 'Water bottle. The one bottle that actually makes me drink enough water.',
        url: 'https://owalalife.com',
      },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Astro" />
    <meta name="description" content="Physical gear I use daily — from everyday carry to workspace setup." />
    <meta name="author" content="Suhas Darsi" />
    <link rel="canonical" href={`${siteUrl}/gear`} />
    <meta property="og:title" content="Gear — Suhas Darsi" />
    <meta property="og:description" content="Physical gear I use daily — from everyday carry to workspace setup." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/gear`} />
    <meta property="og:site_name" content="Suhas Darsi" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@suhas_darsi" />
    <meta name="twitter:creator" content="@suhas_darsi" />
    <meta name="theme-color" content="#faf8f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <title>Gear — Suhas Darsi</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background">
    <Header />

    <main class="max-w-3xl mx-auto px-6 py-8">
      <h1 class="page-title">Gear</h1>

      <p class="page-intro">
        Physical things I use and recommend. Bags, tech, travel gear, workspace setup. If it earns its keep, it's on this list.
      </p>

      {categories.map((category) => (
        category.items.length > 0 && (
          <section class="category-section">
            <h2 class="category-heading">{category.name}</h2>
            <div class="gear-grid">
              {category.items.map((item) => (
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="gear-card">
                  <h3 class="gear-name">{item.name}</h3>
                  <p class="gear-desc">{item.description}</p>
                </a>
              ))}
            </div>
          </section>
        )
      ))}

      {categories.every((c) => c.items.length === 0) && (
        <p class="page-empty">
          Still curating. Check back soon.
        </p>
      )}

      <p class="page-outro">
        Have a recommendation? <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="link">Say hi on X</a>.
      </p>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: var(--text-display);
    }
  }

  .page-intro {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .category-section {
    margin-bottom: 3rem;
  }

  .category-heading {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-muted-foreground);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    padding: 0;
  }

  .gear-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .gear-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .gear-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .gear-card:hover {
    border-color: var(--color-foreground);
    background-color: var(--color-muted);
  }

  .gear-name {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-weight: 500;
    margin: 0 0 0.375rem;
  }

  .gear-desc {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    line-height: 1.5;
    margin: 0;
  }

  .page-empty {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-style: italic;
    color: var(--color-muted-foreground);
    margin-bottom: 3rem;
  }

  .page-outro {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-subtle-border);
  }

  .page-outro .link {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.3s ease;
  }

  .page-outro .link:hover {
    text-decoration-color: var(--color-muted-foreground);
  }
</style>
