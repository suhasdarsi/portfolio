---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();
  posts.forEach((post) => {
    post.data.tags.forEach((tag: string) => tags.add(tag));
  });

  return [...tags].map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;

const allPosts = await getCollection('blog');
const filteredPosts = allPosts
  .filter((post) => post.data.tags.includes(tag))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
---

<BlogLayout title={`#${tag} | Suhas Darsi`} description={`Posts tagged with ${tag}`}>
  <div>
    <a href="/tags" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5"></path>
        <path d="m12 19-7-7 7-7"></path>
      </svg>
      All Tags
    </a>

    <h1 class="tag-page-heading">
      <span class="tag-hash">#</span>{tag}
    </h1>

    <div class="post-list">
      {filteredPosts.map((post) => (
        <article class="post-item">
          <a href={`/blog/${post.id}`} class="post-link">
            <h2 class="post-title">
              {post.data.title}
            </h2>
            <p class="post-desc">
              {post.data.description}
            </p>
            <div class="post-meta">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              {post.data.tags.length > 0 && (
                <div class="tag-list">
                  {post.data.tags.map((t: string) => (
                    <a href={`/tags/${t}`} class={t === tag ? 'tag tag-current' : 'tag'}>{t}</a>
                  ))}
                </div>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</BlogLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    font-size: var(--text-body);
    margin-bottom: 2rem;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .back-link:hover {
    color: var(--color-foreground);
    gap: 0.5rem;
  }

  .back-link svg {
    transition: transform 0.3s ease;
  }

  .back-link:hover svg {
    transform: translateX(-3px);
  }

  .tag-page-heading {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    margin-bottom: 2.5rem;
    text-transform: capitalize;
  }

  .tag-hash {
    color: var(--color-muted-foreground);
    font-weight: 300;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .post-item {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-subtle-border);
  }

  .post-item:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .post-link:hover {
    color: var(--color-muted-foreground);
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  .post-desc {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin: 0 0 0.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-block;
    padding: 0.125rem 0.625rem;
    font-size: var(--text-caption);
    line-height: 1.5;
    letter-spacing: var(--tracking-snug);
    color: var(--color-muted-foreground);
    background-color: var(--color-muted);
    border: 1px solid var(--color-subtle-border);
    border-radius: 100px;
    text-decoration: none;
    transition: color 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;
  }

  .tag:hover {
    color: var(--color-foreground);
    border-color: var(--color-foreground);
  }

  .tag-current {
    font-weight: 600;
  }
</style>
