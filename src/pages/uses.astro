---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeInit from '../components/ThemeInit.astro';

const siteUrl = 'https://suhasdarsi.com';

const digital = [
  { name: 'OpenCode', url: 'https://opencode.ai' },
  { name: 'Zed', url: 'https://zed.dev' },
  { name: 'Claude', url: 'https://claude.ai' },
  { name: 'Perplexity', url: 'https://perplexity.ai' },
  { name: 'Kimi', url: 'https://kimi.moonshot.cn' },
  { name: 'Akiflow', url: 'https://akiflow.com' },
  { name: 'Things 3', url: 'https://culturedcode.com/things/' },
  { name: 'Obsidian', url: 'https://obsidian.md' },
  { name: 'Voice Notes', url: 'https://voicenotes.com' },
  { name: 'Griply', url: 'https://griply.app' },
  { name: 'Figma', url: 'https://figma.com' },
  { name: 'Cloudflare', url: 'https://www.cloudflare.com' },
  { name: 'Plane', url: 'https://plane.so' },
  { name: 'Docmost', url: 'https://docmost.com' },
  { name: 'NocoDB', url: 'https://nocodb.com' },
  { name: 'Beeper', url: 'https://beeper.com' },
  { name: 'Helium', url: 'https://heliumbrowser.com' },
  { name: 'TypeWhisperer', url: 'https://github.com/TypeWhisper/typewhisper-mac' },
  { name: 'Steam', url: 'https://store.steampowered.com' },
];

const physical = [
  { name: 'Mac Mini M4', url: 'https://www.apple.com/mac-mini/' },
  { name: 'iPad Pro M4 11"', url: 'https://www.apple.com/ipad-pro/' },
  { name: 'iPhone 15', url: 'https://www.apple.com/iphone-15/' },
  { name: 'AirPods Pro 2', url: 'https://www.apple.com/airpods-pro/' },
  { name: 'Amazfit Helio Band', url: 'https://www.amazfit.com' },
  { name: 'Keychron K8 Pro', url: 'https://www.keychron.com/products/keychron-k8-pro' },
  { name: 'Damoshark M3', url: 'https://www.damoshark.com' },
  { name: 'HyperX SoloCast', url: 'https://www.hyperx.com/products/hyperx-solocast-usb-microphone' },
  { name: 'INUI 10,000mAh 45W', url: 'https://www.inui.tech' },
  { name: 'Owala FreeSip 945ml', url: 'https://owalalife.com' },
  { name: 'Pakt Travel Backpack 3', url: 'https://pakt.one', review: '/notes/pakt-travel-backpack-3-review' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Astro" />
    <meta name="description" content="Things I use — digital tools and physical gear that earn their keep." />
    <meta name="author" content="Suhas Darsi" />
    <link rel="canonical" href={`${siteUrl}/uses`} />
    <meta property="og:title" content="Uses — Suhas Darsi" />
    <meta property="og:description" content="Things I use — digital tools and physical gear that earn their keep." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/uses`} />
    <meta property="og:site_name" content="Suhas Darsi" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@suhas_darsi" />
    <meta name="twitter:creator" content="@suhas_darsi" />
    <meta name="theme-color" content="#faf8f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <title>Uses — Suhas Darsi</title>
    <ThemeInit />
  </head>
  <body class="min-h-screen bg-background">
    <Header />

    <main class="max-w-3xl mx-auto px-6 py-8">
      <h1 class="page-title">Uses</h1>

      <p class="page-intro">
        Things I use daily — digital tools and physical gear. Some I pay for, some I self-host, all of them earn their place. This is a living document.
      </p>

      <section class="section">
        <h2 class="section-heading">Digital</h2>
        <ul class="item-list">
          {digital.map((item) => (
            <li class="item">
              <div class="item-content">
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-name">{item.name}</a>
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-arrow" aria-label={`Open ${item.name}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7"/>
                    <path d="M7 7h10v10"/>
                  </svg>
                </a>
              </div>
            </li>
          ))}
        </ul>
      </section>

      <section class="section">
        <h2 class="section-heading">Physical</h2>
        <ul class="item-list">
          {physical.map((item) => (
            <li class="item">
              <div class="item-content">
                <div class="item-main">
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-name">{item.name}</a>
                  {item.review && (
                    <a href={item.review} class="item-review">Review</a>
                  )}
                </div>
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-arrow" aria-label={`Open ${item.name}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7"/>
                    <path d="M7 7h10v10"/>
                  </svg>
                </a>
              </div>
            </li>
          ))}
        </ul>
      </section>

      <p class="page-outro">
        Have a recommendation? <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="link">Say hi on X</a>.
      </p>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: var(--text-display);
    }
  }

  .page-intro {
    font-size: var(--text-body-lg);
    color: var(--color-muted-foreground);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .section {
    padding: 0;
    margin-bottom: 3rem;
    width: 100%;
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-muted-foreground);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
  }

  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .item {
    border-bottom: 1px solid var(--color-subtle-border);
    width: 100%;
    transition: background-color 0.15s ease;
  }

  .item:first-child {
    border-top: 1px solid var(--color-subtle-border);
  }

  .item:hover {
    background-color: var(--color-subtle);
  }

  .item-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
  }

  .item-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .item-name {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .item-name:hover {
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-decoration-color: var(--color-subtle-border);
    text-underline-offset: 3px;
  }

  .item-review {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted-foreground);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: 999px;
    transition: all 0.2s ease;
    white-space: nowrap;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .item-review:hover {
    color: var(--color-foreground);
    border-color: var(--color-foreground);
    background-color: var(--color-subtle);
  }

  .item-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .item-arrow:hover {
    background-color: var(--color-muted);
    color: var(--color-foreground);
  }

  @media (max-width: 480px) {
    .item-content {
      gap: 0.75rem;
    }

    .item-main {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }

  .page-outro {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    margin-top: 3rem;
  }

  .page-outro .link {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.3s ease;
  }

  .page-outro .link:hover {
    text-decoration-color: var(--color-muted-foreground);
  }
</style>
