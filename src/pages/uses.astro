---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://suhasdarsi.com';

const categories = [
  {
    name: 'Code',
    apps: [
      {
        name: 'OpenCode',
        description: 'Primary AI coding agent. How this site gets built.',
        url: 'https://opencode.ai',
      },
      {
        name: 'Zed',
        description: 'Daily code editor. Fast, minimal, and gets out of the way.',
        url: 'https://zed.dev',
      },
    ],
  },
  {
    name: 'AI',
    apps: [
      {
        name: 'Claude',
        description: 'Go-to LLM for reasoning and writing.',
        url: 'https://claude.ai',
      },
      {
        name: 'Perplexity',
        description: 'Research and quick answers with sources.',
        url: 'https://perplexity.ai',
      },
      {
        name: 'Kimi',
        description: 'Long-context model for deep dives.',
        url: 'https://kimi.moonshot.cn',
      },
    ],
  },
  {
    name: 'Productivity',
    apps: [
      {
        name: 'Akiflow',
        description: 'Calendar and task management. Where my day gets planned.',
        url: 'https://akiflow.com',
      },
      {
        name: 'Things 3',
        description: 'Personal task manager. Clean, focused, and a joy to use.',
        url: 'https://culturedcode.com/things/',
      },
      {
        name: 'Obsidian',
        description: 'Second brain. Where raw thinking lives before it becomes a note.',
        url: 'https://obsidian.md',
      },
      {
        name: 'Voice Notes',
        description: 'Voice-to-text for capturing thoughts on the go.',
        url: 'https://voicenotes.com',
      },
      {
        name: 'Griply',
        description: 'Goal planner. Where bigger-picture goals get tracked.',
        url: 'https://griply.app',
      },
    ],
  },
  {
    name: 'Design',
    apps: [
      {
        name: 'Figma',
        description: 'UI design and prototyping.',
        url: 'https://figma.com',
      },
    ],
  },
  {
    name: 'Infrastructure',
    apps: [
      {
        name: 'Cloudflare',
        description: 'Hosting, DNS, and deployment. Where this site lives.',
        url: 'https://www.cloudflare.com',
      },
      {
        name: 'Plane',
        description: 'Project management. Self-hosted, clean UI, no bloat.',
        url: 'https://plane.so',
      },
      {
        name: 'Docmost',
        description: 'Internal documentation. Collaborative wiki for self-hosted setups.',
        url: 'https://docmost.com',
      },
      {
        name: 'NocoDB',
        description: 'Airtable alternative. Turns any database into a smart spreadsheet.',
        url: 'https://nocodb.com',
      },
    ],
  },
  {
    name: 'Communication',
    apps: [
      {
        name: 'Beeper',
        description: 'Unified inbox for all messaging. One app, every channel.',
        url: 'https://beeper.com',
      },
    ],
  },
  {
    name: 'Browser',
    apps: [
      {
        name: 'Helium',
        description: 'Lightweight browser for floating video and quick tasks.',
        url: 'https://heliumbrowser.com',
      },
    ],
  },
  {
    name: 'Writing',
    apps: [
      {
        name: 'TypeWhisperer',
        description: 'Distraction-free writing.',
        url: 'https://github.com/TypeWhisper/typewhisper-mac',
      },
    ],
  },
  {
    name: 'Gaming',
    apps: [
      {
        name: 'Steam',
        description: 'Dota. Always Dota.',
        url: 'https://store.steampowered.com',
      },
    ],
  },
  {
    name: 'Gaming',
    apps: [
      {
        name: 'Steam',
        description: 'Dota. Always Dota.',
        url: 'https://store.steampowered.com',
      },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Astro" />
    <meta name="description" content="Apps and tools I use daily — from engineering to design to everyday carry." />
    <meta name="author" content="Suhas Darsi" />
    <link rel="canonical" href={`${siteUrl}/uses`} />
    <meta property="og:title" content="Uses — Suhas Darsi" />
    <meta property="og:description" content="Apps and tools I use daily — from engineering to design to everyday carry." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/uses`} />
    <meta property="og:site_name" content="Suhas Darsi" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@suhas_darsi" />
    <meta name="twitter:creator" content="@suhas_darsi" />
    <meta name="theme-color" content="#faf8f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <title>Uses — Suhas Darsi</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background">
    <Header />

    <main class="max-w-3xl mx-auto px-6 py-8">
      <h1 class="page-title">Uses</h1>

      <p class="page-intro">
        Apps and tools I use daily. Some I pay for, some I self-host, all of them earn their place. This page is a living document — it changes as my workflow evolves.
      </p>

      {categories.map((category) => (
        category.apps.length > 0 && (
          <section class="category-section">
            <h2 class="category-heading">{category.name}</h2>
            <div class="app-grid">
              {category.apps.map((app) => (
                <a href={app.url} target="_blank" rel="noopener noreferrer" class="app-card">
                  <h3 class="app-name">{app.name}</h3>
                  <p class="app-desc">{app.description}</p>
                </a>
              ))}
            </div>
          </section>
        )
      ))}

      <p class="page-outro">
        Have a recommendation? <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="link">Say hi on X</a>.
      </p>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: var(--text-display);
    }
  }

  .page-intro {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .category-section {
    margin-bottom: 3rem;
  }

  .category-heading {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-muted-foreground);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    padding: 0;
  }

  .app-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .app-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .app-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .app-card:hover {
    border-color: var(--color-foreground);
    background-color: var(--color-muted);
  }

  .app-name {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-weight: 500;
    margin: 0 0 0.375rem;
  }

  .app-desc {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    line-height: 1.5;
    margin: 0;
  }

  .page-outro {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-subtle-border);
  }

  .page-outro .link {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.3s ease;
  }

  .page-outro .link:hover {
    text-decoration-color: var(--color-muted-foreground);
  }
</style>
