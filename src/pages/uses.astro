---
import BlogLayout from '../layouts/BlogLayout.astro';

const digital = [
  { name: 'OpenCode', url: 'https://opencode.ai' },
  { name: 'Zed', url: 'https://zed.dev' },
  { name: 'Claude', url: 'https://claude.ai' },
  { name: 'Perplexity', url: 'https://perplexity.ai' },
  { name: 'Kimi', url: 'https://kimi.moonshot.cn' },
  { name: 'Akiflow', url: 'https://akiflow.com' },
  { name: 'Things 3', url: 'https://culturedcode.com/things/' },
  { name: 'Obsidian', url: 'https://obsidian.md' },
  { name: 'Voice Notes', url: 'https://voicenotes.com' },
  { name: 'Griply', url: 'https://griply.app' },
  { name: 'Figma', url: 'https://figma.com' },
  { name: 'Cloudflare', url: 'https://www.cloudflare.com' },
  { name: 'Plane', url: 'https://plane.so' },
  { name: 'Docmost', url: 'https://docmost.com' },
  { name: 'NocoDB', url: 'https://nocodb.com' },
  { name: 'Beeper', url: 'https://beeper.com' },
  { name: 'Helium', url: 'https://heliumbrowser.com' },
  { name: 'TypeWhisperer', url: 'https://github.com/TypeWhisper/typewhisper-mac' },
  { name: 'Steam', url: 'https://store.steampowered.com' },
];

const physical = [
  { name: 'Mac Mini M4', url: 'https://www.apple.com/mac-mini/' },
  { name: 'iPad Pro M4 11"', url: 'https://www.apple.com/ipad-pro/' },
  { name: 'iPhone 15', url: 'https://www.apple.com/iphone-15/' },
  { name: 'AirPods Pro 2', url: 'https://www.apple.com/airpods-pro/' },
  { name: 'Amazfit Helio Band', url: 'https://www.amazfit.com' },
  { name: 'Keychron K8 Pro', url: 'https://www.keychron.com/products/keychron-k8-pro' },
  { name: 'Damoshark M3', url: 'https://www.damoshark.com' },
  { name: 'HyperX SoloCast', url: 'https://www.hyperx.com/products/hyperx-solocast-usb-microphone' },
  { name: 'INUI 10,000mAh 45W', url: 'https://www.inui.tech' },
  { name: 'Owala FreeSip 945ml', url: 'https://owalalife.com' },
  { name: 'Pakt Travel Backpack 3', url: 'https://pakt.one' },
];
---

<BlogLayout title="Uses — Suhas Darsi" description="Things I use — digital tools and physical gear that earn their keep.">
  <h1 class="page-title">Uses</h1>

  <p class="page-intro">
    Things I use daily — digital tools and physical gear. Some I pay for, some I self-host, all of them earn their place. This is a living document.
  </p>

  <section class="section">
    <h2 class="section-heading">Digital</h2>
    <ul class="item-list">
      {digital.map((item) => (
        <li class="item">
          <div class="item-content">
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-name">{item.name}</a>
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-arrow" aria-label={`Open ${item.name}`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7"/>
                <path d="M7 7h10v10"/>
              </svg>
            </a>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2 class="section-heading">Physical</h2>
    <ul class="item-list">
      {physical.map((item) => (
        <li class="item">
          <div class="item-content">
            <div class="item-main">
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-name">{item.name}</a>
              {item.review && (
                <a href={item.review} class="item-review">Review</a>
              )}
            </div>
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-arrow" aria-label={`Open ${item.name}`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7"/>
                <path d="M7 7h10v10"/>
              </svg>
            </a>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <p class="page-outro">
    Have a recommendation? <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="link link-underline">Say hi on X</a>.
  </p>
</BlogLayout>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.035em;
    line-height: 1.08;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: var(--text-display);
    }
  }

  .page-intro {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    color: var(--color-body-text);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .section {
    padding: 0;
    margin-bottom: 4rem;
    width: 100%;
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-muted-foreground);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
  }

  .item-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  @media (min-width: 640px) {
    .item-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .item {
    border: 0;
    border-radius: var(--radius-cards);
    background: var(--color-subtle);
    width: 100%;
    min-width: 0;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .item:first-child {
    border-top: 0;
  }

  .item:hover {
    background-color: var(--color-muted);
    transform: translateY(-1px);
  }

  .item-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 3.75rem;
    padding: 0.85rem 1rem;
  }

  .item-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .item-name {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 450;
    color: var(--color-foreground);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .item-name:hover {
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-decoration-color: var(--color-subtle-border);
    text-underline-offset: 3px;
  }

  .item-review {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted-foreground);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-buttons);
    transition: all 0.2s ease;
    white-space: nowrap;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .item-review:hover {
    color: var(--color-foreground);
    border-color: var(--color-foreground);
    background-color: var(--color-subtle);
  }

  .item-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--color-muted-foreground);
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .item-arrow:hover {
    background-color: var(--color-muted);
    color: var(--color-foreground);
  }

  @media (max-width: 480px) {
    .item-content {
      gap: 0.75rem;
    }

    .item-main {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }

  .page-outro {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-muted-foreground);
    margin-top: 3rem;
  }

  .page-outro .link {
    color: var(--color-foreground);
  }
</style>
