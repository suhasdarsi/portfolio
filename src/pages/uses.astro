---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://suhasdarsi.com';

const digital = [
  { name: 'OpenCode', description: 'Primary AI coding agent', url: 'https://opencode.ai' },
  { name: 'Zed', description: 'Daily code editor', url: 'https://zed.dev' },
  { name: 'Claude', description: 'Go-to LLM for reasoning and writing', url: 'https://claude.ai' },
  { name: 'Perplexity', description: 'Research with sources', url: 'https://perplexity.ai' },
  { name: 'Kimi', description: 'Long-context model for deep dives', url: 'https://kimi.moonshot.cn' },
  { name: 'Akiflow', description: 'Calendar and task management', url: 'https://akiflow.com' },
  { name: 'Things 3', description: 'Personal task manager', url: 'https://culturedcode.com/things/' },
  { name: 'Obsidian', description: 'Second brain', url: 'https://obsidian.md' },
  { name: 'Voice Notes', description: 'Voice-to-text on the go', url: 'https://voicenotes.com' },
  { name: 'Griply', description: 'Goal planner', url: 'https://griply.app' },
  { name: 'Figma', description: 'UI design and prototyping', url: 'https://figma.com' },
  { name: 'Cloudflare', description: 'Hosting, DNS, deployment', url: 'https://www.cloudflare.com' },
  { name: 'Plane', description: 'Self-hosted project management', url: 'https://plane.so' },
  { name: 'Docmost', description: 'Internal documentation wiki', url: 'https://docmost.com' },
  { name: 'NocoDB', description: 'Smart spreadsheets', url: 'https://nocodb.com' },
  { name: 'Beeper', description: 'Unified messaging inbox', url: 'https://beeper.com' },
  { name: 'Helium', description: 'Lightweight browser', url: 'https://heliumbrowser.com' },
  { name: 'TypeWhisperer', description: 'Distraction-free writing', url: 'https://github.com/TypeWhisper/typewhisper-mac' },
  { name: 'Steam', description: 'Dota. Always Dota.', url: 'https://store.steampowered.com' },
];

const physical = [
  { name: 'Mac Mini M4', description: 'Primary desktop', url: 'https://www.apple.com/mac-mini/' },
  { name: 'iPad Pro M4 11"', description: 'Portable workstation', url: 'https://www.apple.com/ipad-pro/' },
  { name: 'iPhone 15', description: 'Daily driver', url: 'https://www.apple.com/iphone-15/' },
  { name: 'AirPods Pro 2', description: 'Everyday earbuds', url: 'https://www.apple.com/airpods-pro/' },
  { name: 'Amazfit Helio Band', description: 'Fitness tracking', url: 'https://www.amazfit.com' },
  { name: 'Keychron K8 Pro', description: 'Mechanical keyboard', url: 'https://www.keychron.com/products/keychron-k8-pro' },
  { name: 'Damoshark M3', description: 'Lightweight mouse', url: 'https://www.damoshark.com' },
  { name: 'HyperX SoloCast', description: 'USB microphone', url: 'https://www.hyperx.com/products/hyperx-solocast-usb-microphone' },
  { name: 'INUI 10,000mAh 45W', description: 'Compact powerbank', url: 'https://www.inui.tech' },
  { name: 'Owala FreeSip 945ml', description: 'Water bottle', url: 'https://owalalife.com' },
  { name: 'Pakt Travel Backpack 3', description: 'One bag for travel and EDC', url: 'https://pakt.one', review: '/notes/pakt-travel-backpack-3-review' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Astro" />
    <meta name="description" content="Things I use — digital tools and physical gear that earn their keep." />
    <meta name="author" content="Suhas Darsi" />
    <link rel="canonical" href={`${siteUrl}/uses`} />
    <meta property="og:title" content="Uses — Suhas Darsi" />
    <meta property="og:description" content="Things I use — digital tools and physical gear that earn their keep." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/uses`} />
    <meta property="og:site_name" content="Suhas Darsi" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@suhas_darsi" />
    <meta name="twitter:creator" content="@suhas_darsi" />
    <meta name="theme-color" content="#faf8f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <title>Uses — Suhas Darsi</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background">
    <Header />

    <main class="max-w-3xl mx-auto px-6 py-8">
      <h1 class="page-title">Uses</h1>

      <p class="page-intro">
        Things I use daily — digital tools and physical gear. Some I pay for, some I self-host, all of them earn their place. This is a living document.
      </p>

      <section class="section">
        <h2 class="section-heading">Digital</h2>
        <ul class="item-list">
          {digital.map((item) => (
            <li>
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-link">
                <span class="item-name">{item.name}</span>
                <span class="item-desc">{item.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="section">
        <h2 class="section-heading">Physical</h2>
        <ul class="item-list">
          {physical.map((item) => (
            <li>
              <div class="item-row">
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-link">
                  <span class="item-name">{item.name}</span>
                  <span class="item-desc">{item.description}</span>
                </a>
                {item.review && (
                  <a href={item.review} class="item-review">Review</a>
                )}
              </div>
            </li>
          ))}
        </ul>
      </section>

      <p class="page-outro">
        Have a recommendation? <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="link">Say hi on X</a>.
      </p>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: var(--text-display);
    }
  }

  .page-intro {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .section {
    padding: 0;
    margin-bottom: 3rem;
    width: 100%;
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-muted-foreground);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .item-list li {
    border-bottom: 1px solid var(--color-subtle-border);
    width: 100%;
  }

  .item-list li:last-child {
    border-bottom: none;
  }

  .item-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .item-link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.2s ease;
    width: 100%;
  }

  .item-link:hover {
    color: var(--color-muted-foreground);
  }

  .item-name {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-weight: 500;
    min-width: 0;
  }

  .item-desc {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-align: right;
    justify-self: end;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .item-review {
    font-size: var(--text-small);
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    white-space: nowrap;
    transition: text-decoration-color 0.2s ease;
  }

  .item-review:hover {
    text-decoration-color: var(--color-foreground);
  }

  @media (max-width: 480px) {
    .item-link {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .item-desc {
      justify-self: start;
      text-align: left;
    }

    .item-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  .page-outro {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-subtle-border);
  }

  .page-outro .link {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.3s ease;
  }

  .page-outro .link:hover {
    text-decoration-color: var(--color-muted-foreground);
  }

</style>
