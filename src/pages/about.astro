---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteUrl = 'https://suhasdarsi.com';

const thinkingAreas = [
  {
    name: 'AI Safety',
    description: 'Building foundational infrastructure for safe AI adoption. Exploring governance, security risks, and what it takes to build trustworthy systems at scale.',
  },
  {
    name: 'Product',
    description: 'Observations from shipping real things in a fast-moving space. What works, what doesn\'t, and the messy reality of building products people actually use.',
  },
  {
    name: 'Bags',
    description: 'The intersection of design, function, and everyday carry. What a good bag reveals about how someone moves through the world.',
  },
  {
    name: 'Travel',
    description: 'Notes from the road. How different places think about technology, infrastructure, and the spaces in between.',
  },
  {
    name: 'Infrastructure',
    description: 'Self-hosting, systems thinking, and the quiet satisfaction of things that just work. The tools behind the thinking.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Astro" />
    <meta name="description" content="About Suhas Darsi — Co-Founder at SuperAlign, writing about AI safety, product, bags, travel, and infrastructure." />
    <meta name="author" content="Suhas Darsi" />
    <link rel="canonical" href={`${siteUrl}/about`} />
    <meta property="og:title" content="About — Suhas Darsi" />
    <meta property="og:description" content="Co-Founder at SuperAlign, writing about AI safety, product, bags, travel, and infrastructure." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/about`} />
    <meta property="og:site_name" content="Suhas Darsi" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@suhas_darsi" />
    <meta name="twitter:creator" content="@suhas_darsi" />
    <meta name="theme-color" content="#faf8f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <title>About — Suhas Darsi</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background">
    <Header />

    <main class="max-w-3xl mx-auto px-6 py-8">
      <h1 class="page-title">About</h1>

      <div class="prose-section">
        <p>
          I'm a co-founder at <a href="https://superalign.ai" class="link">SuperAlign</a>, where we help security teams see, understand, and control AI adoption across their organizations.
        </p>
        <p>
          My background is in Computer Vision research at IIIT Hyderabad. These days I spend most of my time thinking about AI governance, the security risks of enterprise AI, and what it takes to build trustworthy systems at scale.
        </p>
        <p>
          This site is my digital garden — a place for thinking in public. Some pieces are polished, most are works in progress. The topics reflect what I'm actively engaged with:
        </p>
      </div>

      <div class="topics-grid">
        {thinkingAreas.map((area) => (
          <a href={`/notes?topic=${area.name}`} class="topic-card">
            <h2 class="topic-name">{area.name}</h2>
            <p class="topic-desc">{area.description}</p>
          </a>
        ))}
      </div>

      <div class="contact-section">
        <h2 class="contact-heading">Get in touch</h2>
        <div class="contact-links">
          <a href="https://www.linkedin.com/in/suhasdarsi/" target="_blank" rel="noopener noreferrer" class="contact-link">
            LinkedIn
          </a>
          <a href="https://x.com/suhas_darsi" target="_blank" rel="noopener noreferrer" class="contact-link">
            X / Twitter
          </a>
          <a href="https://booking.akiflow.com/suhas--e823" target="_blank" rel="noopener noreferrer" class="contact-link">
            Book a meeting
          </a>
        <a href="/notes" class="contact-link">
          Notes
        </a>
        <a href="/rss.xml" class="contact-link">
          RSS feed
        </a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: var(--text-display);
    }
  }

  .prose-section {
    margin-bottom: 3rem;
  }

  .prose-section p {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .prose-section a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: text-decoration-color 0.3s ease;
  }

  .prose-section a:hover {
    text-decoration-color: var(--color-muted-foreground);
  }

  .topics-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .topic-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
  }

  .topic-card:hover {
    border-color: var(--color-foreground);
    background-color: var(--color-muted);
  }

  .topic-name {
    font-family: var(--font-serif);
    font-size: var(--text-title);
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .topic-desc {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    line-height: 1.6;
    margin: 0;
  }

  .contact-section {
    border-top: 1px solid var(--color-subtle-border);
    padding-top: 2.5rem;
  }

  .contact-heading {
    font-family: var(--font-serif);
    font-size: var(--text-title);
    margin: 0 0 1.25rem;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .contact-link {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-decoration-color: #a19c87;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 0.3s ease, text-decoration-color 0.3s ease;
  }

  .contact-link:hover {
    color: var(--color-foreground);
    text-decoration-color: var(--color-muted-foreground);
  }
</style>
