---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="404 — Page Not Found | Suhas Darsi" description="Page not found — Suhas Darsi">
  <h1 class="error-code">404</h1>
  <p class="error-message">This page doesn't exist.</p>
  <p class="error-hint">It might have been moved, deleted, or you may have mistyped the URL.</p>
  <div class="error-actions">
    <a href="/" class="error-link error-link-primary">Go home</a>
    <a href="/notes" class="error-link">Browse notes</a>
  </div>
</BlogLayout>

<style>
  .error-code {
    font-family: var(--font-serif);
    font-size: 6rem;
    font-weight: 400;
    color: var(--color-muted-foreground);
    margin: 0 0 1rem;
    line-height: 1;
    letter-spacing: 0;
  }

  .error-message {
    font-family: var(--font-serif);
    font-size: var(--text-title);
    color: var(--color-foreground);
    margin: 0 0 0.5rem;
  }

  .error-hint {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .error-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    transition: all 0.3s ease;
  }

  .error-link:hover {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .error-link-primary {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .error-link-primary:hover {
    background: var(--color-muted-foreground);
    border-color: var(--color-muted-foreground);
    color: var(--color-background);
  }
</style>
