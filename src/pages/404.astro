---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="404 — Page Not Found | Suhas Darsi" description="Page not found — Suhas Darsi">
  <h1 class="error-code">404</h1>
  <p class="error-message">This page doesn't exist.</p>
  <p class="error-hint">It might have been moved, deleted, or you may have mistyped the URL.</p>
  <div class="error-actions">
    <a href="/" class="error-link error-link-primary">Go home</a>
    <a href="/notes" class="error-link">Browse notes</a>
  </div>
  <p class="error-search-label">Or search across all notes:</p>
  <div class="error-search-wrap">
    <input type="text" id="error-search-input" class="error-search-input" placeholder="Search notes..." aria-label="Search all notes" autocomplete="off" />
    <div class="error-search-results" id="error-search-results"></div>
  </div>
</BlogLayout>

<script>
  import Fuse from 'fuse.js';

  const searchData = document.getElementById('search-data');
  const searchPosts = searchData ? JSON.parse(searchData.textContent || '[]') : [];
  const input = document.getElementById('error-search-input') as HTMLInputElement;
  const results = document.getElementById('error-search-results');

  if (searchPosts.length > 0) {
    const fuse = new Fuse(searchPosts, {
      keys: ['title', 'description'],
      threshold: 0.3,
    });

    input?.addEventListener('input', () => {
      const query = input.value.trim();
      if (!query) { if (results) results.innerHTML = ''; return; }
      const hits = fuse.search(query).slice(0, 5);
      if (results) {
        results.innerHTML = hits.map((hit) =>
          `<a href="/notes/${encodeURIComponent(hit.item.id)}" class="error-search-result">${hit.item.title}</a>`
        ).join('');
      }
    });
  }
</script>

<style>
  .error-code {
    font-family: var(--font-serif);
    font-size: 6rem;
    font-weight: 400;
    color: var(--color-muted-foreground);
    margin: 0 0 1rem;
    line-height: 1;
    letter-spacing: 0;
  }

  .error-message {
    font-family: var(--font-serif);
    font-size: var(--text-title);
    color: var(--color-foreground);
    margin: 0 0 0.5rem;
  }

  .error-hint {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .error-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--color-subtle-border);
    border-radius: var(--radius-sm);
    transition: all 0.3s ease;
  }

  .error-link:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
  }

  .error-link:hover {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .error-link-primary {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .error-link-primary:hover {
    background: var(--color-muted-foreground);
    border-color: var(--color-muted-foreground);
    color: var(--color-background);
  }

  .error-search-label {
    font-size: var(--text-body);
    color: var(--color-muted-foreground);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    text-align: center;
  }

  .error-search-wrap {
    max-width: 24rem;
    margin: 0 auto;
    text-align: left;
  }

  .error-search-input {
    width: 100%;
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--color-foreground);
    background: none;
    border: 1px solid var(--color-subtle-border);
    padding: 0.5rem 0.75rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .error-search-input:focus {
    border-color: var(--color-foreground);
  }

  .error-search-results {
    display: flex;
    flex-direction: column;
    margin-top: 0.25rem;
  }

  .error-search-result {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: var(--text-body);
    color: var(--color-foreground);
    text-decoration: none;
    border: 1px solid var(--color-subtle-border);
    border-top: none;
    transition: background 0.15s ease;
  }

  .error-search-result:hover {
    background: var(--color-muted);
  }

  .error-search-result:first-child {
    border-top: 1px solid var(--color-subtle-border);
  }
</style>
